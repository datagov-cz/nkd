}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177923/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177923/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX httpList: <http://plugins.linkedpipes.com/ontology/e-httpGetFiles#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
<http://localhost/resource/configuration> a httpList:Configuration ;
    httpList:reference ?dataset .

?catalog a dcat:Catalog;
    dcat:dataset ?dataset ;
    dcat:endpointURL ?endpoint .

?dataset a httpList:Reference ;
    chunked:fileName ?mdfilename ;
    httpList:group ?catalog_filename ;
    httpList:fileUri ?dataset ;
    httpList:fileName ?dataset_filename ;
    httpList:header ?agentHeader .
 
?agentHeader a httpList:Header ;
    httpList:key \"User-Agent\" ;
    httpList:value \"nkod/0.0.1\" .

}
WHERE { 
  ?catalog a dcat:Catalog, httpList:Reference ;
           dcat:endpointURL ?endpoint ;
           chunked:fileName ?mdfilename ;
           httpList:fileName ?catalog_filename .
  
  BIND(IRI(STR(?endpoint)) as ?downloaded_catalog)
  
  ?downloaded_catalog dcat:dataset ?dataset .
     
  BIND(REPLACE(STR(?dataset),\"[:/\\\\?=]\",\"-\") as ?dataset_filename)
  BIND(IRI(CONCAT(STR(?dataset),\"/agent-header\")) as ?agentHeader)

}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177924/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177924/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX httpList: <http://plugins.linkedpipes.com/ontology/e-httpGetFiles#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
<http://localhost/resource/configuration> a httpList:Configuration ;
    httpList:reference ?catalog .

?catalog a dcat:Catalog, httpList:Reference ;
    chunked:fileName ?mdfilename ;
    dcat:endpointURL ?endpoint ;
    httpList:fileUri ?endpoint ;
    httpList:fileName ?filename ;
    httpList:header ?agentHeader .

?agentHeader a httpList:Header ;
    httpList:key \"User-Agent\" ;
    httpList:value \"nkod/0.0.1\" .
}
WHERE {
  ?catalog a dcat:Catalog, nkod:DcatApLkod ;
           chunked:fileName ?mdfilename ;
           dcat:endpointURL ?endpoint .
  
  BIND(REPLACE(STR(?catalog),\"[:/\\\\?#&]\",\"-\") as ?filename)
  BIND(IRI(CONCAT(STR(?catalog),\"/agent-header\")) as ?agentHeader)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779242/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779242/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX ovm: <https://data.gov.cz/slovník/ovm/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

CONSTRUCT {
?ds a ds:DatováSchránka.
?be ds:datová-schránka ?ds ;
    gr:legalName ?name;
    skos:notation ?notation;
    <urn:ICO> ?ico .
} 
WHERE {
?ds a ds:DatováSchránka.
?be ds:datová-schránka ?ds ;
    skos:notation ?notation;
    <urn:ICO> ?ico .
OPTIONAL { ?be gr:legalName ?name .}

#Only used ones
  [] a nkod:PřijatýZáznam ;
     nkod:datová-schránka-poskytovatele ?ds .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779264/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779264/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

PREFIX status: <http://purl.org/adms/status/> 
PREFIX tz: <https://data.gov.cz/slovník/nkod/typ-datové-sady-dle-zdroje/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT { 
?catalog adms:status status:Withdrawn ;
    nkod:zrušovatel ?ovm .  
} 
WHERE {
?catalog a dcat:Catalog ;
         adms:status status:Withdrawn .

# chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
[] chunked:fileName ?filename .
[] nkod:jméno-souboru ?filename ;
   nkod:id-datové-zprávy ?iddz ;
   nkod:datová-schránka-poskytovatele ?ds ;
   nkod:datová-zpráva-přijata ?rmodified .
  
?ds ^ds:datová-schránka ?ovm .
?ovm gr:legalName ?pname ;
     skos:notation ?ovmid .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779271/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779271/1>
    a <http://plugins.linkedpipes.com/ontology/t-mustache#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#addFirstFlag> true;
    <http://plugins.linkedpipes.com/ontology/t-mustache#addFirstFlagControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#class> "http://localhost/temp/Root";
    <http://plugins.linkedpipes.com/ontology/t-mustache#classControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#escapeForJson> true;
    <http://plugins.linkedpipes.com/ontology/t-mustache#escapeForJsonControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#template> """{{!
  PREFIX mustache: <http://plugins.linkedpipes.com/ontology/t-mustache#>
}}
{
\"_id\" : \"keywords_by_publishers_en\",
\"jsonld\": [
{{#http://localhost/temp/entry}}
{{^mustache:first}},{{/mustache:first}}
{
        \"@type\": [\"urn:Keyword\"],
        \"http://www.w3.org/2004/02/skos/core#prefLabel\": {
          \"@language\": \"{{{urn:keyword_lang}}}\",
          \"@value\": \"{{{urn:keyword}}}\"
        },
        \"urn:usedByPublishersCount\": {{http://www.w3.org/1999/02/22-rdf-syntax-ns#value}}
    }
{{/http://localhost/temp/entry}}
]
}""";
    <http://plugins.linkedpipes.com/ontology/t-mustache#templateControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779275/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779275/1>
    a <http://plugins.linkedpipes.com/ontology/t-unpackZip#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-unpackZip#usePrefix> false;
    <http://plugins.linkedpipes.com/ontology/t-unpackZip#usePrefixControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779286/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779286/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
DELETE { 
  ?dataset dcat:contactPoint ?cp .
} 
WHERE 
{
   ?dataset dcat:contactPoint ?cp .
  FILTER NOT EXISTS { ?cp vcard:fn|vcard:hasEmail [] .}
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177929/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177929/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>

PREFIX status: <http://purl.org/adms/status/> 
PREFIX tz: <https://data.gov.cz/slovník/nkod/typ-datové-sady-dle-zdroje/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT { 
?catalog_iri a dcat:Catalog, ?type ;
    dcat:endpointURL ?catalog_endpoint ;
    dcterms:title ?title ;
    dcat:contactPoint ?cp ;
    foaf:homepage ?homepage ;
    dcterms:publisher ?ovm ;
    chunked:fileName ?filename .

?cp a ?cptype ;
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .  
  
?ovm gr:legalName ?pname .
} 
WHERE {
?catalog a dcat:Catalog, ?type ;
  dcat:endpointURL ?catalog_endpoint ;
  dcterms:title ?title .

FILTER ( ?type != dcat:Catalog)

OPTIONAL { ?catalog dcat:contactPoint ?cp . 
?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { ?cp vcard:hasEmail ?cpemail . }
}
OPTIONAL { ?catalog foaf:homepage ?homepage . }
  
# chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
[] chunked:fileName ?filename .
[] nkod:jméno-souboru ?filename ;
   nkod:id-datové-zprávy ?iddz ;
   nkod:datová-schránka-poskytovatele ?ds ;
   nkod:datová-zpráva-přijata ?rmodified .
  
?ds ^ds:datová-schránka ?ovm .
?ovm gr:legalName ?pname ;
     skos:notation ?ovmid .

  BIND (IRI(CONCAT(\"https://data.gov.cz/zdroj/lokální-katalogy/\", ?ovmid, \"/\", ?iddz)) as ?catalog_iri)
  FILTER NOT EXISTS {?catalog_iri adms:status status:Withdrawn; nkod:zrušovatel ?ovm .}
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

