    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#query> """PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX req: <http://plugins.linkedpipes.com/ontology/x-httpRequest#>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX pojem: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX a-sgov-104-pojem: <https://slovník.gov.cz/agendový/104/pojem/>

CONSTRUCT {
?ovm pojem:má-datovou-schránku-orgánu-veřejné-moci ?dsIRI ;
  		pojem:má-identifikátor-orgánu-veřejné-moci ?ovmID ;
  		pojem:má-název-orgánu-veřejné-moci ?ovmNázev .
  
  	 ?dsIRI pojem:má-identifikátor-datové-schránky ?dsIDstring.
} WHERE {

  	 ?ovm pojem:má-datovou-schránku-orgánu-veřejné-moci ?dsIRI ;
  		pojem:má-identifikátor-orgánu-veřejné-moci ?ovmID ;
  		pojem:má-název-orgánu-veřejné-moci ?ovmNázev .
OPTIONAL { ?ovm
      a-sgov-104-pojem:má-datum-ukončení-výkonu-působnosti-orgánu-veřejné-moci ?ukonceni
  }
  FILTER(!bound(?ukonceni) || ?ukonceni > now())
 ${VALUES} 
BIND(STRDT(?dsID, xsd:string) AS ?dsIDstring)
  
  	 ?dsIRI pojem:má-identifikátor-datové-schránky ?dsIDstring.
}""";
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#skipOnError> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#skipOnErrorControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#useAuthentication>
