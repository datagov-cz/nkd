<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779443/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779443/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"publisher_keywords_cs.json\" ;
   local:entry ?entryID.
?entryID a local:Entry ;
   rdf:value ?počet_poskytovatelů ;
   <urn:keyword> ?kwstring ;
   <urn:keyword_lang> ?lang .
}
WHERE {
{
SELECT ?keyword (count (distinct ?poskytovatel ) as ?počet_poskytovatelů)
WHERE 
{
?datova_sada a dcat:Dataset ; 
    dcterms:publisher ?poskytovatel ;
    ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> ;
    dcat:keyword ?keyword .
}
GROUP BY ?keyword
#HAVING (?počet_poskytovatelů > 1)
}
  BIND(IRI(CONCAT(\"http://localhost/temp/\", LANG(?keyword), \"/\", ENCODE_FOR_URI(STR(?keyword)))) as ?entryID)
  BIND(STR(?keyword) as ?kwstring)
  BIND(LANG(?keyword) as ?lang)
  FILTER(LANG(?keyword) = \"cs\")
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779446/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779446/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX req: <http://plugins.linkedpipes.com/ontology/x-httpRequest#>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>

CONSTRUCT {
?ds a req:Task ;
  req:url \"https://www.mojedatovaschranka.cz/sds/ws/call\" ;
  req:method \"POST\" ;
  req:postContentAsBody true ;
  req:fileName ?fileName ;
  req:content ?content .

?content a req:Content ;
  req:fileReference ?fileName .
}
WHERE {
  [] a nkod:PřijatýZáznam ;
     nkod:datová-schránka-poskytovatele ?ds .
  FILTER NOT EXISTS {
    ?ovm ds:datová-schránka ?ds .
  }
  
  BIND(IRI(CONCAT(STR(?ds), \"/content\")) as ?content)
  BIND(REPLACE(STR(?ds), \".*/([^/]+)$\", \"$1\") as ?code)
  BIND(CONCAT(?code, \".xml\") as ?fileName)
  
  #Testovací DS
  FILTER(?code NOT IN(\"6i8gfv8\", \"fchgfwy\", \"minfin\"))
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779448/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779448/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>

#Toto je proto, že dle https://ofn.gov.cz/rozhraní-katalogů-otevřených-dat/2019-04-04/ je email chybně jako literál. V nové verzi je to IRI - je třeba ho převést.
DELETE { 
 ?cp vcard:hasEmail ?emailStr .
} 
INSERT { 
 ?cp vcard:hasEmail ?emailIRI . 
}
WHERE 
{
 ?cp vcard:hasEmail ?emailStr .
  FILTER(isLiteral(?emailStr))
  BIND(IRI(CONCAT(\"mailto:\", ?emailStr)) as ?emailIRI)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779449/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779449/1>
    a <http://plugins.linkedpipes.com/ontology/t-chunkedToGraph#Configuration> .
}

