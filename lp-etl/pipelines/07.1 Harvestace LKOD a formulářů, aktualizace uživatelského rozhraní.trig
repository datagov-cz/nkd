    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
CONSTRUCT { 
  ?theme skos:inScheme ?scheme .
}
WHERE { 
  ?dataset dcat:theme ?theme .
  FILTER(STRSTARTS(STR(?theme), \"https://slovník.gov.cz/\"))
  FILTER EXISTS { ?theme skos:prefLabel [] }
  BIND(<https://slovník.gov.cz/základní/pojem/typ-vztahu> AS ?scheme)
}""";
