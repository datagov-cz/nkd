    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX cc: <http://creativecommons.org/ns#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>
PREFIX eu-cc0: <http://publications.europa.eu/resource/authority/licence/CC0>
PREFIX eu-ccby: <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>

PREFIX nead: <https://data.gov.cz/podmínky-užití/neobsahuje-autorská-díla/>
PREFIX neadb: <https://data.gov.cz/podmínky-užití/není-autorskoprávně-chráněnou-databází/>
PREFIX nezp: <https://data.gov.cz/podmínky-užití/není-chráněna-zvláštním-právem-pořizovatele-databáze/>
PREFIX cc0: <https://creativecommons.org/publicdomain/zero/1.0/>
PREFIX ccby: <https://creativecommons.org/licenses/by/4.0/>

INSERT { 
  ?pu ?vztah ?eulicence .
}
WHERE 
{
  ?pu a pu:Specifikace ;
      pu:autorské-dílo ?autorskéDílo ;
      pu:databáze-jako-autorské-dílo ?autorskáDatabáze ;
      pu:databáze-chráněná-zvláštními-právy ?zvláštníPrávo .
  
  VALUES (?autorskéDílo ?autorskáDatabáze ?zvláštníPrávo ?vztah ?eulicence) {
    ( nead: neadb: nezp: skos:narrowMatch eu-cc0:)
    ( nead: neadb: cc0: skos:narrowMatch eu-cc0:)
    ( ccby: neadb: nezp: skos:narrowMatch eu-ccby:)
    ( ccby: neadb: cc0: skos:narrowMatch eu-ccby:)
    ( neadb: ccby: nezp: skos:narrowMatch eu-ccby:)
    ( neadb: ccby: cc0: skos:narrowMatch eu-ccby:)
    ( ccby: ccby: nezp: skos:narrowMatch eu-ccby:)
    ( ccby: ccby: cc0: skos:narrowMatch eu-ccby:)
    ( ccby: ccby: ccby: skos:exactMatch eu-ccby:)
  }
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001d8ef-b5a7/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001d8ef-b5a7/1>
    a <http://plugins.linkedpipes.com/ontology/e-filesFromLocal#Configuration>;
    <http://plugins.linkedpipes.com/ontology/e-filesFromLocal#path> "data/lp-etl/nkod-cache/ssp/typy-vztahů-ttl";
