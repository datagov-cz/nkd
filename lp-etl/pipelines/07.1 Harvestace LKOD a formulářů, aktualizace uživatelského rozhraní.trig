<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779425/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779425/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

CONSTRUCT {
 ?ds a <urn:MustacheRoot>; 
 <urn:ds> ?code ;
 <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> ?fileName .
} 
WHERE {
  [] a nkod:PřijatýZáznam ;
     nkod:datová-schránka-poskytovatele ?ds .
  
  BIND(REPLACE(STR(?ds), \".*/([^/]+)$\", \"$1\") as ?code)
  BIND(CONCAT(?code, \".xml\") as ?fileName)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

