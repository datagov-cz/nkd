<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779138/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779138/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """construct {
  ?s <http://www.w3.org/2004/02/skos/core#prefLabel> ?label .
} where {
  ?s <http://www.w3.org/2004/02/skos/core#inScheme> <http://publications.europa.eu/resource/authority/file-type> ;
    <http://www.w3.org/2004/02/skos/core#prefLabel> ?label .
  FILTER(LANG(?label) = 'en')
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779139/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779139/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX esl: <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunkedList#>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>
PREFIX localhost: <http://localhost/>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>

CONSTRUCT { 
  ?configiri a esl:Task ;
    esl:query ?query ;
    esl:fileName ?filename ;
    esl:endpoint ?endpoint ;
    esl:chunkSize \"20\"  .
} 
WHERE 
{ 
  { 
    SELECT DISTINCT ?catalog ?endpoint 
    WHERE {
      ?catalog dcat:endpointURL ?endpoint . 
    } 
  }
   
BIND(CONCAT(\"\"\"
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX schema: <http://schema.org/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX dcatap: <http://data.europa.eu/r5r/>

PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>

CONSTRUCT {
  <\"\"\", STR(?catalog), \"\"\"> a dcat:Catalog ;
    dcat:dataset ?dataset .

  ?dataset a ?datasetType, dcat:Dataset ;
    dcterms:title ?title ;
    dcterms:description ?description ;
    dcat:theme ?theme ;
    dcterms:accrualPeriodicity ?accrualPeriodicity ;
    dcat:keyword ?keyword ;
    dcterms:spatial ?spatial ;
    dcterms:temporal ?temporal ;
    dcat:contactPoint ?cp ;
    foaf:page ?page ;
    dcterms:conformsTo ?conformsTo ;
    dcat:spatialResolutionInMeters ?spatialResolution ;
    dcat:temporalResolution ?temporalResolution ;
    dcat:inSeries ?topDataset ;
    dcat:distribution ?distribution ;
    dcatap:applicableLegislation ?datasetApplicableLegislation ;
    dcatap:hvdCategory ?datasethvdCategory .

  ?cp a ?cptype; 
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .

  ?temporal a dcterms:PeriodOfTime; 
    dcat:startDate ?finalStartDate ;
    dcat:endDate ?finalEndDate .

  ?distribution a dcat:Distribution ;
    dcat:downloadURL ?ddURL ;
    dcat:accessURL ?daURL ;
    dcterms:format ?dformat ;
    dcat:mediaType ?dmimeType ;
    dcterms:conformsTo ?dconformsTo ;
    dcat:compressFormat ?dcompressFormat ;
    dcat:packageFormat ?dpackageFormat ;
    dcatap:applicableLegislation ?distributionApplicableLegislation ;
    dcterms:title ?dtitle .

  ?distribution pu:specifikace ?tou .
  ?tou a pu:Specifikace ;
    pu:autorské-dílo ?touGeneral ;
    pu:databáze-jako-autorské-dílo ?touDatabase ;
    pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
    pu:osobní-údaje ?touPersonalData ;
    pu:autor ?touGeneralAuthor ;
    pu:autor-databáze ?touDatabaselAuthor .

  ?distribution dcat:accessService ?dataService . 

  ?dataService a dcat:DataService ;
    dcterms:title ?sTitle ;
    dcterms:conformsTo ?sConformsTo ;
    dcat:endpointURL ?sEndpointURL ;
    dcat:endpointDescription ?sEndpointDescription ;
    dcatap:applicableLegislation ?dataServiceApplicableLegislation ;
    dcatap:hvdCategory ?dataServicehvdCategory ;
    foaf:page ?dataServiceDocumentation ;
    dcat:contactPoint ?dscp .

  ?dscp a ?dscptype; 
    vcard:fn ?dscpfn ;
    vcard:hasEmail ?dscpemail .

}
WHERE { 
  ${VALUES}

  ?dataset a ?datasetType ;
    dcterms:title ?title ;
    dcterms:description ?description ;
    dcat:theme ?theme ;
    dcterms:accrualPeriodicity ?accrualPeriodicity ;
    dcat:keyword ?keyword ;
    dcterms:spatial ?spatial .

    FILTER(isIRI(?spatial) && isIRI(?theme) && isIRI(?accrualPeriodicity))  
  OPTIONAL {
    ?dataset dcterms:temporal ?temporal . 
    OPTIONAL { ?temporal dcat:startDate ?startDate . }
    OPTIONAL { ?temporal dcat:endDate ?endDate . }
    OPTIONAL { ?temporal schema:startDate ?schemaStartDate . }
    OPTIONAL { ?temporal schema:endDate ?schemaEndDate . }
  }

  OPTIONAL {
    ?dataset dcat:contactPoint ?cp . 

    ?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { ?cp vcard:hasEmail ?cpemail . }
  }

  OPTIONAL { ?dataset foaf:page ?page . }
  OPTIONAL { ?dataset dcterms:conformsTo ?conformsTo . }
  OPTIONAL { ?dataset dcat:spatialResolutionInMeters ?spatialResolution . }
  OPTIONAL { ?dataset dcat:temporalResolution ?temporalResolution . }
  OPTIONAL { ?dataset dcterms:isPartOf|dcat:inSeries ?topDataset . }
  OPTIONAL { 
    ?dataset dcatap:applicableLegislation ?datasetApplicableLegislation . 
    FILTER(isIRI(?datasetApplicableLegislation))
  }
  OPTIONAL { 
    ?dataset dcatap:hvdCategory ?datasethvdCategory . 
    FILTER(isIRI(?datasethvdCategory))
  }  

  OPTIONAL {
    ?dataset dcat:distribution ?distribution .
    FILTER(isIRI(?distribution))

    ?distribution a dcat:Distribution ;
             dcat:accessURL ?daURL ;
             pu:specifikace ?tou .

    ?tou a pu:Specifikace ;
             pu:autorské-dílo ?touGeneral ;
             pu:databáze-jako-autorské-dílo ?touDatabase ;
             pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
             pu:osobní-údaje ?touPersonalData .

    OPTIONAL { ?tou pu:autor ?touGeneralAuthor . }
    OPTIONAL { ?tou pu:autor-databáze ?touDatabaselAuthor . }

    OPTIONAL { 
      ?distribution dcatap:applicableLegislation ?distributionApplicableLegislation . 
      FILTER(isIRI(?distributionApplicableLegislation))
    }
    OPTIONAL { ?distribution dcat:downloadURL ?ddURL . }
    OPTIONAL { ?distribution dcterms:format ?dformat . }
    OPTIONAL { ?distribution dcat:mediaType ?dmimeType . }
    OPTIONAL { ?distribution dcterms:conformsTo ?dconformsTo . }
    OPTIONAL { ?distribution dcat:compressFormat ?dcompressFormat . }
    OPTIONAL { ?distribution dcat:packageFormat ?dpackageFormat . }
    OPTIONAL { ?distribution dcterms:title ?dtitle . }

    OPTIONAL { 
      ?distribution dcat:accessService ?dataService . 
      FILTER(isIRI(?dataService))

      ?dataService a dcat:DataService ;
                    dcterms:title ?sTitle ;
                    dcat:endpointURL ?sEndpointURL .
      OPTIONAL { ?dataService dcat:endpointDescription ?sEndpointDescription .}
      OPTIONAL { ?dataService dcterms:conformsTo ?sConformsTo .}
      OPTIONAL { 
        ?dataService dcatap:applicableLegislation ?dataServiceApplicableLegislation . 
        FILTER(isIRI(?dataServiceApplicableLegislation))
      }
      OPTIONAL { 
        ?dataService dcatap:hvdCategory ?dataServicehvdCategory . 
        FILTER(isIRI(?dataServicehvdCategory))
      }
      OPTIONAL { 
        ?dataService foaf:page ?dataServiceDocumentation . 
        FILTER(isIRI(?dataServiceDocumentation))
      }
      OPTIONAL { ?dataService dcat:contactPoint ?dscp . 
        ?dscp a ?dscptype.
        OPTIONAL { ?dscp vcard:fn ?dscpfn . }
        OPTIONAL { 
          ?dscp vcard:hasEmail ?dscpemail . 
          FILTER(isIRI(?dscpemail))
        }
      }
    }
  }
  VALUES ?datasetType { dcat:Dataset dcat:DatasetSeries }
  BIND(IF(BOUND(?startDate), ?startDate, ?schemaStartDate) AS ?finalStartDate)
  BIND(IF(BOUND(?endDate), ?endDate, ?schemaEndDate) AS ?finalEndDate)
}
\"\"\") as ?query)

	BIND(CONCAT(REPLACE(STR(?catalog),\"[:/\\\\.]\",\"_\"),\".csv\") as ?filename)
	BIND(UUID() as ?configiri)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177914/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177914/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX schema: <http://schema.org/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX status: <http://purl.org/adms/status/>
PREFIX dcatap: <http://data.europa.eu/r5r/>

PREFIX tz: <https://data.gov.cz/slovník/nkod/typ-datové-sady-dle-zdroje/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>

PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
?dataset_new a dcat:Dataset, tz:Formulář ;
    dcterms:title ?title ;
    dcterms:description ?description ;
	dcat:theme ?theme ;
	dcterms:accrualPeriodicity ?accrualPeriodicity ;
	dcat:keyword ?keyword ;
    dcterms:spatial ?spatial ;
    dcterms:temporal ?temporal_new ;
	dcat:contactPoint ?cp_new ;
	foaf:page ?page ;
    dcterms:conformsTo ?conformsTo ;
    dcat:spatialResolutionInMeters ?spatialResolution ;
    dcat:temporalResolution ?temporalResolution ;
    dcterms:publisher ?publisher ;
    dcterms:identifier ?dataset_old_str ;
    dcat:distribution ?distribution_new ;
    dcatap:applicableLegislation ?datasetApplicableLegislation ;
    dcatap:hvdCategory ?datasethvdCategory .

?cp_new a ?cptype; 
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .

?temporal_new a dcterms:PeriodOfTime; 
    dcat:startDate ?finalStartDate ;
    dcat:endDate ?finalEndDate .

?publisher a foaf:Agent, foaf:Organization;
    foaf:name ?pname .

?distribution_new a dcat:Distribution ;
    dcat:downloadURL ?ddURL ;
    dcat:accessURL ?daURL ;
    dcterms:format ?dformat ;
	dcat:mediaType ?dmimeType ;
	dcterms:conformsTo ?dconformsTo ;
    dcat:compressFormat ?dcompressFormat ;
    dcat:packageFormat ?dpackageFormat ;
    dcterms:title ?dtitle_cs, ?dtitle_en ;
    dcatap:applicableLegislation ?distributionApplicableLegislation .
  
?distribution_new pu:specifikace ?tou_new .
?tou_new a pu:Specifikace ;
    pu:autorské-dílo ?touGeneral ;
	pu:databáze-jako-autorské-dílo ?touDatabase ;
    pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
	pu:osobní-údaje ?touPersonalData ;
	pu:autor ?touGeneralAuthor ;
	pu:autor-databáze ?touDatabaselAuthor .

?distribution_new dcat:accessService ?dataservice_new . 
?dataservice_new a dcat:DataService ;
    dcterms:title ?sTitle_cs, ?sTitle_en ;
    dcterms:conformsTo ?sConformsTo ;
    dcat:endpointURL ?sEndpointURL ;
    dcat:endpointDescription ?sEndpointDescription ;
    dcatap:applicableLegislation ?dataServiceApplicableLegislation ;
    dcatap:hvdCategory ?dataServicehvdCategory ;
    foaf:page ?dataServiceDocumentation ;
    dcat:contactPoint ?dscp_new .

?dscp_new a ?dscptype; 
    vcard:fn ?dscpfn ;
    vcard:hasEmail ?dscpemail .

?record_new a dcat:CatalogRecord;
    dcterms:issued ?rissued ;
    dcterms:modified ?rmodified ;
    foaf:primaryTopic ?dataset_new ;
    dcterms:language <http://publications.europa.eu/resource/authority/language/CES>,
        <http://publications.europa.eu/resource/authority/language/ENG> ;
    dcterms:conformsTo <https://semiceu.github.io/DCAT-AP/releases/3.0.0> .
}
WHERE {
# chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
[] chunked:fileName ?filename .
[] nkod:jméno-souboru ?filename ;
   nkod:id-datové-zprávy ?iddz ;
   nkod:datová-schránka-poskytovatele ?ds ;
   nkod:datová-zpráva-přijata ?rmodified .
  
?ds ^ds:datová-schránka ?publisher .
?publisher gr:legalName ?pname ;
     skos:notation ?publisherid .

?dataset a dcat:Dataset ;
    dcterms:title ?title .
  
    OPTIONAL { ?dataset dcterms:description ?description . }
    OPTIONAL { 
    	?dataset dcat:theme ?theme . 
    	FILTER( isIRI(?theme) )
  	}
    OPTIONAL { 
    	?dataset dcterms:accrualPeriodicity ?accrualPeriodicity .
    	FILTER( isIRI(?accrualPeriodicity) )
  	}
    OPTIONAL { ?dataset dcat:keyword ?keyword . }
    OPTIONAL { 
    	?dataset dcterms:spatial ?spatial . 
    	FILTER( isIRI(?spatial) )
  	}

    OPTIONAL { ?dataset dcterms:temporal ?temporal . 
    OPTIONAL { ?temporal dcat:startDate ?startDate . }
    OPTIONAL { ?temporal dcat:endDate ?endDate . }
    OPTIONAL { ?temporal schema:startDate ?schemaStartDate . }
    OPTIONAL { ?temporal schema:endDate ?schemaEndDate . }
    BIND(IF(BOUND(?startDate), ?startDate, ?schemaStartDate) AS ?finalStartDate)
    BIND(IF(BOUND(?endDate), ?endDate, ?schemaEndDate) AS ?finalEndDate)
  }
  
  OPTIONAL { ?dataset dcat:contactPoint ?cp . 
    ?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { ?cp vcard:hasEmail ?cpemail . }
  }

  OPTIONAL { 
    ?dataset dcatap:applicableLegislation ?datasetApplicableLegislation . 
    FILTER(isIRI(?datasetApplicableLegislation))
  }
  OPTIONAL { 
    ?dataset dcatap:hvdCategory ?datasethvdCategory . 
    FILTER(isIRI(?datasethvdCategory))
  }  
  OPTIONAL { 
    ?dataset foaf:page ?page . 
    FILTER( isIRI(?page) )
  }
  OPTIONAL { 
    ?dataset dcterms:conformsTo ?conformsTo . 
    FILTER( isIRI(?conformsTo) )
  }
  OPTIONAL { ?dataset dcat:spatialResolutionInMeters ?spatialResolution . }
  OPTIONAL { ?dataset dcat:temporalResolution ?temporalResolution . }
  
  ?dataset dcat:distribution ?distribution .
  ?distribution a dcat:Distribution ;
    dcat:accessURL ?daURL .

  #vše nepovinné kvůli historickým NKOD formulářům
  OPTIONAL { 
    ?distribution pu:specifikace ?tou .
	?tou a pu:Specifikace ;
    	pu:autorské-dílo ?touGeneral ;
		pu:databáze-jako-autorské-dílo ?touDatabase ;
        pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
		pu:osobní-údaje ?touPersonalData .

    OPTIONAL { ?tou pu:autor ?touGeneralAuthor . }
    OPTIONAL { ?tou pu:autor-databáze ?touDatabaselAuthor . }
  }

  OPTIONAL { 
    ?distribution dcat:downloadURL ?ddURL . 
    FILTER( isIRI(?ddURL) )
  }
  OPTIONAL { 
    ?distribution dcatap:applicableLegislation ?distributionApplicableLegislation . 
    FILTER(isIRI(?distributionApplicableLegislation))
  }
  OPTIONAL { 
    ?distribution dcterms:format ?dformat . 
    FILTER( isIRI(?dformat) )
  }
  OPTIONAL { 
    ?distribution dcat:mediaType ?dmimeType . 
    FILTER( isIRI(?dmimeType) )
  }
  OPTIONAL { 
    ?distribution dcterms:conformsTo ?dconformsTo .
    FILTER( isIRI(?dconformsTo) )
  }
  OPTIONAL { 
    ?distribution dcat:compressFormat ?dcompressFormat . 
    FILTER( isIRI(?dcompressFormat) )
  }
  OPTIONAL { 
    ?distribution dcat:packageFormat ?dpackageFormat . 
    FILTER( isIRI(?dpackageFormat) )
  }
  OPTIONAL { 
    ?distribution dcterms:title ?dtitle_en .
    FILTER(LANGMATCHES(LANG(?dtitle_en), \"en\"))
  }
  OPTIONAL {
    ?distribution dcterms:title ?dtitle_cs ;
    FILTER(LANGMATCHES(LANG(?dtitle_cs), \"cs\"))
  }

  OPTIONAL { 
      ?distribution dcat:accessService ?dataService . 
      ?dataService a dcat:DataService ;
                   dcat:endpointURL ?sEndpointURL .
    	FILTER( isIRI(?sEndpointURL) )
    
    OPTIONAL { 
        ?dataService dcterms:title ?sTitle_en .
        FILTER(LANGMATCHES(LANG(?sTitle_en), \"en\"))
    }
    OPTIONAL {
        ?dataService dcterms:title ?sTitle_cs ;
        FILTER(LANGMATCHES(LANG(?sTitle_cs), \"cs\"))
    }
    OPTIONAL { 
      ?dataService dcat:endpointDescription ?sEndpointDescription .
      FILTER( isIRI(?sEndpointDescription) )
    }
    OPTIONAL { 
      ?dataService dcterms:conformsTo ?sConformsTo .
      FILTER( isIRI(?sConformsTo) )
    }
    OPTIONAL { 
      ?dataService dcatap:applicableLegislation ?dataServiceApplicableLegislation . 
      FILTER(isIRI(?dataServiceApplicableLegislation))
    }
    OPTIONAL { 
      ?dataService dcatap:hvdCategory ?dataServicehvdCategory . 
      FILTER(isIRI(?dataServicehvdCategory))
    }
    OPTIONAL { 
      ?dataService foaf:page ?dataServiceDocumentation . 
      FILTER(isIRI(?dataServiceDocumentation))
    }
    OPTIONAL { ?dataService dcat:contactPoint ?dscp . 
      ?dscp a ?dscptype.
      OPTIONAL { ?dscp vcard:fn ?dscpfn . }
      OPTIONAL { 
        ?dscp vcard:hasEmail ?dscpemail . 
        FILTER(isIRI(?dscpemail))
      }
    }          
  }
  BIND (STRDT(STR(?dataset), xsd:anyURI) as ?dataset_old_str)
  BIND (CONCAT(\"https://data.gov.cz/zdroj/datové-sady/\", ?publisherid, \"/\", ?iddz) as ?new_IRI_base)
  BIND (IRI(?new_IRI_base) as ?dataset_candidate)
  
  OPTIONAL { 
    ?dataset_candidate nkod:upravuje ?starýDataset .
    ?starýDataset nkod:issued ?oldissued ;
                nkod:max_čas_úpravy ?max_čas_úpravy ;
                nkod:issuer ?publisher_original .
  }
  
  # Buďto se nejedná o editaci, nebo je původní posytovatel stejný jako ten editující
  # To je žádoucí stav
  FILTER ( !BOUND(?starýDataset) || (?publisher_original = ?publisher))
  
  # Přiřadit IRI editované datové sady, pokud se jedná o poslední editaci
  BIND (IF(BOUND(?starýDataset) && (?max_čas_úpravy = ?rmodified), 
      ?starýDataset, 
      ?dataset_candidate) AS ?dataset_new)
  
  # Datum registrace starší datové sady
  BIND(IF(BOUND(?oldissued), ?oldissued, ?rmodified) AS ?rissued)

  # Zkopírovat data z CatalogRecord k datové sadě
  BIND(?rissued AS ?issued)
  BIND(?rmodified AS ?modified)
  
  BIND (IRI(CONCAT(STR(?dataset_new),\"/distribuce/\", MD5(CONCAT(STR(?daURL), IF(BOUND(?dtitle_cs), STR(?dtitle_cs), \"\"), IF(BOUND(?dmimeType), STR(?dmimeType), \"\"))))) as ?distribution_new)
  BIND (IRI(CONCAT(STR(?distribution_new),\"/datová-služba/\", MD5(CONCAT(STR(?sTitle_cs),STR(?sEndpointURL),IF(BOUND(?sEndpointDescription), STR(?sEndpointDescription),\"\"))))) as ?dataservice_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/záznam\")) as ?record_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/kontaktní-bod\")) as ?cp_new)
  BIND (IRI(CONCAT(STR(?dataservice_new),\"/kontaktní-bod\")) as ?dscp_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/časové-pokrytí\")) as ?temporal_new)
  BIND (IRI(CONCAT(STR(?distribution_new),\"/podmínky-užití\")) as ?tou_new)
  
  # Zkontrolovat, že datová sada není zrušená
  FILTER NOT EXISTS {?dataset_new adms:status status:Withdrawn; nkod:zrušovatel ?publisher .}
  
  # Exclude the original dataset which was edited
  FILTER NOT EXISTS {?dataset_candidate nkod:oeditoval ?publisher .}
  
  # Exclude edits which are not the last one
  FILTER ( !BOUND(?starýDataset) || (?max_čas_úpravy = ?rmodified) )
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779140/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779140/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstructToFileList#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructToFileList#deduplication>
      false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructToFileList#deduplicationControl>
      <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779142/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779142/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX rov: <http://www.w3.org/ns/regorg#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX ovm: <https://data.gov.cz/slovník/ovm/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

CONSTRUCT {
?ds a ds:DatováSchránka.
?be ds:datová-schránka ?ds ;
    gr:legalName ?name;
    skos:notation ?notation ;
    <urn:ICO> ?ico .
} 
WHERE {
?ds a ds:DatováSchránka ;
    ^ovm:datováSchránka ?be .
?be skos:notation ?notation ;
    rov:registration ?id .
?id a adms:Identifier ;
    skos:prefLabel ?ico .
OPTIONAL { ?be gr:legalName ?name .}
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779143/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779143/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:    <http://www.w3.org/ns/dcat#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:   <http://localhost/temp/>
PREFIX skos:    <http://www.w3.org/2004/02/skos/core#>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"filter.json\" ;
   local:themes ?theme.
?theme local:cs ?csstring.
?theme local:en ?enstring.
}
WHERE {

?datova_sada dcat:theme ?theme ;
             ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> .
    
?theme skos:prefLabel ?cs_label, ?en_label .
    
FILTER(langMatches(LANG(?cs_label), \"cs\"))
FILTER(langMatches(LANG(?en_label), \"en\"))

BIND(STR(?cs_label) as ?csstring)
BIND(STR(?en_label) as ?enstring)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791434-867c/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791434-867c/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"filter.json\" ;
   local:publishers ?publisher .

  ?publisher local:cs ?csstring.
  ?publisher local:en ?enstring.
  
}
WHERE {
  ?catalog dcterms:publisher ?publisher .
  
  OPTIONAL {
    ?publisher gr:legalName ?cs_label .
    FILTER(langMatches(LANG(?cs_label), \"cs\"))
    BIND(STR(?cs_label) as ?csstring)
  }
  
  OPTIONAL {
    ?publisher gr:legalName ?en_label .
    FILTER(langMatches(LANG(?en_label), \"en\"))
    BIND(STR(?en_label) as ?enstring)
  }
  
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779145/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779145/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>

PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

INSERT {
  ?dataset nkod:lkod ?catalog .
}
WHERE { 
  ?catalog dcat:dataset ?dataset.
  FILTER(?catalog != <https://data.gov.cz/zdroj/katalog/NKOD>)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779153/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779153/configuration>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>

PREFIX esl: <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointList#>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

CONSTRUCT 
{ 
  ?catalog a esl:Task ;
    esl:query ?query ;
    esl:group ?uritext ;
    esl:endpoint ?uritext ;
} 
WHERE { 
  ?catalog a dcat:Catalog, nkod:DcatApSparql ;
    dcat:endpointURL ?endpoint .

  BIND(STR(?endpoint) as ?uritext)

  BIND(CONCAT(\"\"\"PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
<\"\"\", STR(?catalog), \"\"\"> dcat:endpointURL \\\"\"\"\",?uritext,\"\"\"\\\"^^xsd:anyURI ;
dcat:dataset ?dataset .
} WHERE { 
{ ?dataset a dcat:Dataset . } UNION { ?dataset a dcat:DatasetSeries }
}\"\"\") as ?query)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779155/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779155/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlSelectMultiple#Configuration> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779158/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779158/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>

PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT 
{ 
  ?catalog chunked:fileName ?mdfilename .
} 
WHERE 
{ 
  ?catalog a dcat:Catalog, nkod:DcatApSparql ;
  chunked:fileName ?mdfilename .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779159/configuration> {
