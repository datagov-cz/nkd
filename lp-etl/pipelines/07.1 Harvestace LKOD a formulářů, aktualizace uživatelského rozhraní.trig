<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00014e56-9998/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00014e56-9998/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>

INSERT { 
  ?dataset adms:identifier ?Identifier.
  
  ?Identifier a adms:Identifier ;
    skos:notation ?uriID ;
    dcterms:creator <https://rpp-opendata.egon.gov.cz/odrpp/zdroj/orgán-veřejné-moci/17651921> .
}
WHERE 
{
  ?dataset a dcat:Dataset .

  BIND(STR(?dataset) AS ?strDataset)
  BIND(STRDT(?strDataset, xsd:anyURI) AS ?uriID)
  BIND(IRI(CONCAT(?strDataset, \"/identifikátorNKOD\")) AS ?Identifier)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
