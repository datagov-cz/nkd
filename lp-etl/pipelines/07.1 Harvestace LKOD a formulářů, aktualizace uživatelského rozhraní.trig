<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000103b2-a1e9/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000103b2-a1e9/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcatap: <http://data.europa.eu/r5r/>
PREFIX accessRights: <http://publications.europa.eu/resource/authority/access-right/>
PREFIX PSI: <http://data.europa.eu/eli/dir/2019/1024/oj>

INSERT { 
  ?dataset dcatap:applicableLegislation PSI: ;
    dcterms:accessRights accessRights:PUBLIC .
} 
WHERE {
  ?dataset a ?type .
  VALUES ?type { dcat:Dataset dcat:DatasetSeries }
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00010f36-889a/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00010f36-889a/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#deduplication> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#deduplicationControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#query> """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>
PREFIX eu-cc0: <http://publications.europa.eu/resource/authority/licence/CC0>
PREFIX eu-ccby: <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0>

PREFIX nead: <https://data.gov.cz/podmínky-užití/neobsahuje-autorská-díla/>
PREFIX neadb: <https://data.gov.cz/podmínky-užití/není-autorskoprávně-chráněnou-databází/>
PREFIX nezp: <https://data.gov.cz/podmínky-užití/není-chráněna-zvláštním-právem-pořizovatele-databáze/>
PREFIX cc0: <https://creativecommons.org/publicdomain/zero/1.0/>
PREFIX ccby: <https://creativecommons.org/licenses/by/4.0/>

CONSTRUCT { 
  ?pu ?vztah ?eulicence .
}
WHERE 
{
  ?pu a pu:Specifikace ;
      pu:autorské-dílo ?autorskéDílo ;
      pu:databáze-jako-autorské-dílo ?autorskáDatabáze ;
      pu:databáze-chráněná-zvláštními-právy ?zvláštníPrávo .
  
  VALUES (?autorskéDílo ?autorskáDatabáze ?zvláštníPrávo ?vztah ?eulicence) {
    ( nead: neadb: nezp: skos:narrowMatch eu-cc0:)
    ( nead: neadb: cc0: skos:narrowMatch eu-cc0:)
    ( ccby: neadb: nezp: skos:narrowMatch eu-ccby:)
    ( ccby: neadb: cc0: skos:narrowMatch eu-ccby:)
    ( neadb: ccby: nezp: skos:narrowMatch eu-ccby:)
    ( neadb: ccby: cc0: skos:narrowMatch eu-ccby:)
    ( ccby: ccby: nezp: skos:narrowMatch eu-ccby:)
    ( ccby: ccby: cc0: skos:narrowMatch eu-ccby:)
  }
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#softFailControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstructChunked#threadsControl>
      <http://plugins.linkedpipes.com/resource/configuration/None> .
}

