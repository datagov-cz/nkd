    <http://plugins.linkedpipes.com/ontology/t-chunkSplitter#incomingLevelDepth> 1;
    <http://plugins.linkedpipes.com/ontology/t-chunkSplitter#incomingLevelDepthControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
