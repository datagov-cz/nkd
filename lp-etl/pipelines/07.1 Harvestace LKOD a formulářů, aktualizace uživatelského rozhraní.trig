<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317790503-9c97/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317790503-9c97/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#addToChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX pojmy: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>

CONSTRUCT { 
  ?dataset a <https://data.gov.cz/slovník/nkod/vdf/datová-sada-publikující-veřejné-údaje> .
} 
WHERE 
{  
  ?dataset a dcat:Dataset .
  
  ?údaj a pojmy:veřejný-údaj ;
  	pojmy:iri-datové-sady-publikující-veřejný-údaj ?dataset .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779073d-acb7/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779073d-acb7/1>
    a <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#Configuration>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#defaultGraphControl> <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#encodeRdf> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#encodeRdfControl> <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#endpoint> "http://localhost:8891/sparql";
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#endpointControl> <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#handleInvalidData> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#handleInvalidDataControl>
      <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#headerAcceptControl> <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#passwordControl> <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#query> """PREFIX pojmy: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>
PREFIX a104: <https://slovník.gov.cz/agendový/104/pojem/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

CONSTRUCT {
  ?ds nkod:původce-dat <https://rpp-opendata.egon.gov.cz/odrpp/zdroj/orgán-veřejné-moci/00025593> . #ČSÚ
} WHERE {
  ?udaj a pojmy:údaj .
  
  ?os a a104:objekt-nebo-subjekt-údajů ;
      a104:má-údaj ?udaj .
  
  ?udaj a pojmy:údaj ;
      pojmy:iri-datové-sady-publikující-veřejný-údaj ?ds .
  
  FILTER NOT EXISTS {
      ?os a104:sdružuje-údaje-vedené-nebo-vytvářené-v-rámci-agendy ?agenda .
  }
  
}""";
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#useAuthentication> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#useAuthenticationControl>
      <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#useTolerantRepository> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#useTolerantRepositoryControl>
      <http://plugins.linkedpipes.com/resource/configuration/Inherit>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#userNameControl> <http://plugins.linkedpipes.com/resource/configuration/Inherit> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177910/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177910/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#addToChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
CONSTRUCT { 
  ?catalog a dcat:Catalog;
           dcat:dataset ?dataset ;
           dcat:endpointURL ?endpoint .
  ?dataset chunked:fileName ?mdfilename . 
} 
WHERE { 
  ?catalog a dcat:Catalog;
           dcat:dataset ?dataset ;
           dcat:endpointURL ?endpoint .
  ?dataset a dcat:Dataset;
         chunked:fileName ?mdfilename .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779102/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779102/1>
    a <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#commitSize> 50000;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#commitSizeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#mimeType> "";
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#mimeTypeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfGraph#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177911/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177911/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dct: <http://purl.org/dc/terms/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX schema: <http://schema.org/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX dcatap: <http://data.europa.eu/r5r/>

PREFIX tz: <https://data.gov.cz/slovník/nkod/typ-datové-sady-dle-zdroje/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>

PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
  ?catalog dcat:dataset ?dataset_new .

  ?dataset_new a dcat:Dataset, tz:DokumentyDCAT, tz:LKOD ;
    dcterms:title ?title ;
    dcterms:description ?description ;
    dcat:theme ?theme ;
    dcterms:accrualPeriodicity ?accrualPeriodicity ;
    dcat:keyword ?keyword ;
    dcterms:spatial ?spatial ;
    dcterms:temporal ?temporal_new ;
    dcat:contactPoint ?cp_new ;
    foaf:page ?page ;
    dcterms:issued ?issued ;
    dcterms:conformsTo ?conformsTo ;
    dcat:spatialResolutionInMeters ?spatialResolution ;
    dcat:temporalResolution ?temporalResolution ;
    dcat:inSeries ?topDatasetNew ;
    dcat:distribution ?distribution_new ;
    dcterms:publisher ?publisher ;
    dcterms:identifier ?dataset_old_str ;
    dcatap:applicableLegislation ?datasetApplicableLegislation ;
    dcatap:hvdCategory ?datasethvdCategory .

  ?cp_new a ?cptype; 
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .

  ?temporal_new a dcterms:PeriodOfTime; 
    dcat:startDate ?finalStartDate ;
    dcat:endDate ?finalEndDate .

  ?publisher a foaf:Agent, foaf:Organization;
    foaf:name ?pname .

  ?distribution_new a dcat:Distribution ;
    dcat:downloadURL ?ddURL ;
    dcat:accessURL ?daURL ;
    dcterms:format ?dformat ;
    dcat:mediaType ?dmimeType ;
    dcterms:conformsTo ?dconformsTo ;
    dcat:compressFormat ?dcompressFormat ;
    dcat:packageFormat ?dpackageFormat ;
    dcterms:title ?dtitle ;
    dcatap:applicableLegislation ?distributionApplicableLegislation ;
    pu:specifikace ?tou_new .

  ?tou_new a pu:Specifikace ;
    pu:autorské-dílo ?touGeneral ;
    pu:databáze-jako-autorské-dílo ?touDatabase ;
    pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
    pu:osobní-údaje ?touPersonalData ;
    pu:autor ?touGeneralAuthor ;
    pu:autor-databáze ?touDatabaselAuthor .

  ?distribution_new dcat:accessService ?dataservice_new . 
  ?dataservice_new a dcat:DataService ;
    dcterms:title ?sTitle ;
    dcterms:conformsTo ?sConformsTo ;
    dcat:endpointURL ?sEndpointURL ;
    dcat:endpointDescription ?sEndpointDescription ;
    dcterms:identifier ?service_old_str ;
    dcatap:applicableLegislation ?dataServiceApplicableLegislation ;
    dcatap:hvdCategory ?dataServicehvdCategory ;
    foaf:page ?dataServiceDocumentation ;
    dcat:contactPoint ?dscp_new .

  ?dscp_new a ?dscptype; 
    vcard:fn ?dscpfn ;
    vcard:hasEmail ?dscpemail .

  ?record_new a dcat:CatalogRecord;
    dcterms:source ?dataset ;
    foaf:primaryTopic ?dataset_new ;
    dcterms:language <http://publications.europa.eu/resource/authority/language/CES>, <http://publications.europa.eu/resource/authority/language/ENG> ;
    dcterms:conformsTo <https://semiceu.github.io/DCAT-AP/releases/3.0.0> .
}
WHERE {
  [] nkod:jméno-souboru ?filename ;
     nkod:datová-schránka-poskytovatele ?ds ;
     nkod:datová-zpráva-přijata ?rmodified .

  ?ds ^ds:datová-schránka ?publisher .
  ?publisher gr:legalName ?pname ;
             skos:notation ?publisherid .

  ?catalog a dcat:Catalog ;
             dcat:dataset ?dataset .

  ?dataset a dcat:Dataset ;
  # chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
             chunked:fileName ?filename ;
             dcterms:title ?title ;
             dcterms:description ?description ;
             dcat:theme ?theme ;
             dcterms:accrualPeriodicity ?accrualPeriodicity ;
             dcat:keyword ?keyword ;
             dcterms:spatial ?spatial .

  FILTER(isIRI(?spatial) && isIRI(?theme) && isIRI(?accrualPeriodicity))
  OPTIONAL { ?dataset dcterms:temporal ?temporal . 
    OPTIONAL { 
      ?temporal dcat:startDate ?startDate .
      FILTER(REGEX(STR(?startDate), \"[0-9]{4}-[0-9]{2}-[0-9]{2}\") && DATATYPE(?startDate) = xsd:date)
    }
    OPTIONAL { 
      ?temporal dcat:endDate ?endDate . 
      FILTER(REGEX(STR(?endDate), \"[0-9]{4}-[0-9]{2}-[0-9]{2}\") && DATATYPE(?endDate) = xsd:date)
    }
    OPTIONAL { 
      ?temporal schema:startDate ?schemaStartDate . 
      FILTER(REGEX(STR(?schemaStartDate), \"[0-9]{4}-[0-9]{2}-[0-9]{2}\") && DATATYPE(?schemaStartDate) = xsd:date)
    }
    OPTIONAL { 
      ?temporal schema:endDate ?schemaEndDate . 
      FILTER(REGEX(STR(?schemaEndDate), \"[0-9]{4}-[0-9]{2}-[0-9]{2}\") && DATATYPE(?schemaEndDate) = xsd:date)
    }
    BIND(IF(BOUND(?startDate), ?startDate, ?schemaStartDate) AS ?finalStartDate)
    BIND(IF(BOUND(?endDate), ?endDate, ?schemaEndDate) AS ?finalEndDate)
  }

  OPTIONAL { ?dataset dcat:contactPoint ?cp . 
    ?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { 
      ?cp vcard:hasEmail ?cpemail . 
      FILTER(isIRI(?cpemail))
    }
  }

  OPTIONAL { 
    ?dataset dcatap:applicableLegislation ?datasetApplicableLegislation . 
    FILTER(isIRI(?datasetApplicableLegislation))
  }
  OPTIONAL { 
    ?dataset dcatap:hvdCategory ?datasethvdCategory . 
    FILTER(isIRI(?datasethvdCategory))
  }  
  OPTIONAL { 
    ?dataset foaf:page ?page . 
    FILTER(isIRI(?page))
  }
  OPTIONAL { 
    ?dataset dcterms:conformsTo ?conformsTo . 
    FILTER(isIRI(?conformsTo))
  }
  OPTIONAL { ?dataset dcat:spatialResolutionInMeters ?spatialResolution . }
  OPTIONAL { ?dataset dcat:temporalResolution ?temporalResolution . }
  OPTIONAL { 
    ?dataset dcterms:isPartOf|dcat:inSeries ?topDataset . 
    FILTER(isIRI(?topDataset))
  }
  OPTIONAL {
    ?dataset dcat:distribution ?distribution .
    ?distribution a dcat:Distribution ;
             dcat:accessURL ?daURL ;
             pu:specifikace ?tou .

    ?tou a pu:Specifikace ;
             pu:autorské-dílo ?touGeneral ;
             pu:databáze-jako-autorské-dílo ?touDatabase ;
             pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
             pu:osobní-údaje ?touPersonalData .
    FILTER(isIRI(?daURL) && isIRI(?touGeneral) && isIRI(?touDatabase) && isIRI(?touDatabaseExtra) && isIRI(?touPersonalData))

    OPTIONAL { ?tou pu:autor ?touGeneralAuthor . }
    OPTIONAL { ?tou pu:autor-databáze ?touDatabaselAuthor . }

    OPTIONAL { ?distribution dcat:downloadURL ?ddURL . }
    OPTIONAL { 
      ?distribution dcatap:applicableLegislation ?distributionApplicableLegislation . 
      FILTER(isIRI(?distributionApplicableLegislation))
    }
    OPTIONAL { 
      ?distribution dcterms:format ?dformat . 
      FILTER(isIRI(?dformat))
    }
    OPTIONAL { 
      ?distribution dcat:mediaType ?dmimeType . 
      FILTER(isIRI(?dmimeType))
    }
    OPTIONAL { 
      ?distribution dcterms:conformsTo ?dconformsTo . 
      FILTER(isIRI(?dconformsTo))
    }
    OPTIONAL { 
      ?distribution dcat:compressFormat ?dcompressFormat . 
      FILTER(isIRI(?dcompressFormat))
    }
    OPTIONAL { 
      ?distribution dcat:packageFormat ?dpackageFormat . 
      FILTER(isIRI(?dpackageFormat))
    }
    OPTIONAL { ?distribution dcterms:title ?dtitle . }  
    OPTIONAL { 
      ?distribution dcat:accessService ?dataService . 
      ?dataService a dcat:DataService ;
                    dcterms:title ?sTitle ;
                    dcat:endpointURL ?sEndpointURL .
      OPTIONAL { 
        ?dataService dcat:endpointDescription ?sEndpointDescription .
        FILTER(isIRI(?sEndpointDescription))
      }
      OPTIONAL { 
        ?dataService dcterms:conformsTo ?sConformsTo .
        FILTER(isIRI(?sConformsTo))
      }
      OPTIONAL { 
        ?dataService dcatap:applicableLegislation ?dataServiceApplicableLegislation . 
        FILTER(isIRI(?dataServiceApplicableLegislation))
      }
      OPTIONAL { 
        ?dataService dcatap:hvdCategory ?dataServicehvdCategory . 
        FILTER(isIRI(?dataServicehvdCategory))
      }
      OPTIONAL { 
        ?dataService foaf:page ?dataServiceDocumentation . 
        FILTER(isIRI(?dataServiceDocumentation))
      }
      OPTIONAL { ?dataService dcat:contactPoint ?dscp . 
        ?dscp a ?dscptype.
        OPTIONAL { ?dscp vcard:fn ?dscpfn . }
        OPTIONAL { 
          ?dscp vcard:hasEmail ?dscpemail . 
          FILTER(isIRI(?dscpemail))
        }
      }      
      FILTER(isIRI(?sEndpointURL))
    }
  }

  BIND (STRDT(STR(?dataset), xsd:anyURI) as ?dataset_old_str)
  BIND (STRDT(STR(?dataService), xsd:anyURI) as ?service_old_str)
  BIND (CONCAT(\"https://data.gov.cz/zdroj/datové-sady/\", ?publisherid, \"/\") as ?new_IRI_base)
  BIND (IRI(CONCAT(?new_IRI_base, MD5(STR(?dataset)))) as ?dataset_new)
  BIND (IRI(CONCAT(?new_IRI_base, MD5(STR(?topDataset)))) as ?topDatasetNew)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/distribuce/\", MD5(STR(?distribution)))) as ?distribution_new)
  BIND (IRI(CONCAT(STR(?distribution_new),\"/datová-služba/\", MD5(STR(?dataService)))) as ?dataservice_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/záznam\")) as ?record_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/kontaktní-bod\")) as ?cp_new)
  BIND (IRI(CONCAT(STR(?dataservice_new),\"/kontaktní-bod\")) as ?dscp_new)
  BIND (IRI(CONCAT(STR(?distribution_new),\"/podmínky-užití\")) as ?tou_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/časové-pokrytí\")) as ?temporal_new)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779113/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779113/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX local: <http://localhost/temp/>

DELETE {
 ?catalog a dcat:Catalog , ?secondaryType .
}

INSERT 
{
  local:seznam a local:Seznam ;
    local:catalog ?catalog .
  ?catalog local:type ?type ;
    local:cs ?cslabel ;
    local:en ?enlabel .
}
WHERE 
{ 
  ?catalog a dcat:Catalog , ?secondaryType.
  FILTER (?secondaryType != dcat:Catalog)
  BIND(STR(?secondaryType) as ?type)
  
  OPTIONAL {
    ?catalog dcterms:title ?cs_label .
    FILTER(langMatches(LANG(?cs_label), \"cs\"))
    BIND(STR(?cs_label) as ?cslabel)
  }
  OPTIONAL {
    ?catalog dcterms:title ?en_label .
    FILTER(langMatches(LANG(?en_label), \"en\"))
    BIND(STR(?en_label) as ?enlabel)
  }
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779114/configuration> {
