    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#userNameControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317795e08-873f/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317795e08-873f/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>

#Toto je proto, že dle https://ofn.gov.cz/rozhraní-katalogů-otevřených-dat/2019-04-04/ je email chybně jako literál. V nové verzi je to IRI - je třeba ho převést.
DELETE { 
 ?cp vcard:hasEmail ?emailStr .
} 
INSERT { 
 ?cp vcard:hasEmail ?emailIRI . 
}
WHERE 
{
 ?cp vcard:hasEmail ?emailStr .
  FILTER(isLiteral(?emailStr))
  BIND(IRI(CONCAT(\"mailto:\", ?emailStr)) as ?emailIRI)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317795ea1-ae42/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317795ea1-ae42/1>
    a <http://plugins.linkedpipes.com/ontology/e-textHolder#Configuration>;
    <http://plugins.linkedpipes.com/ontology/e-textHolder#content> """{
    \"@context\": [
        \"http://www.w3.org/ns/csvw\",
        {
            \"@language\": \"cs\"
        }
    ],
    \"url\": \"distribuce.csv\",
    \"header\": true,
    \"tableSchema\": {
        \"columns\": [
            {
                \"titles\": \"datová_sada\",
                \"dc:description\": \"IRI datové sady v NKOD.\",
                \"datatype\": \"anyURI\",
                \"required\": true
            },
            {
                \"titles\": \"distribuce\",
                \"dc:description\": \"IRI distribuce datové sady v NKOD.\",
                \"datatype\": \"anyURI\",
                \"required\": true
            },
            {
                \"titles\": \"typ\",
                \"dc:description\": \"Typ distribuce datové sady.\",
                \"datatype\": \"string\"
            },
            {
                \"titles\": \"název\",
                \"dc:description\": \"Název distribuce datové sady.\",
                \"datatype\": \"string\"
            },
            {
                \"titles\": \"autorskéDílo\",
                \"dc:description\": \"Odkaz na podmínky užití týkající se autorského díla.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"databázeAutorskéDílo\",
                \"dc:description\": \"Odkaz na podmínky užití týkající se databáze jako autorského díla.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"zvláštníPrávoPořizovateleDatabáze\",
                \"dc:description\": \"Odkaz na podmínky užití týkající se zvláštního práva pořizovatele databáze.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"osobníÚdaje\",
                \"dc:description\": \"Odkaz na informaci, zda distribuce datové sady obsahuje osobní údaje.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"přístupovéUrl\",
                \"dc:description\": \"Odkaz ke stažení souboru nebo k přístupu k datové službě.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"formátSouboru\",
                \"dc:description\": \"Formát souboru ke stažení.\",
                \"datatype\": \"string\"
            },
            {
                \"titles\": \"mediaTypeSouboru\",
                \"dc:description\": \"Typ média souboru ke stažení.\",
                \"datatype\": \"string\"
            },
            {
                \"titles\": \"odkazKeStažení\",
                \"dc:description\": \"Odkaz ke stažení distribuce datové sady.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"odkazNaSchémaSouboru\",
                \"dc:description\": \"Odkaz na strojově čitelné schéma souboru ke stažení.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"popisPřístupovéhoBoduSlužby\",
                \"dc:description\": \"Odkaz na popis přístupového bodu datové služby.\",
                \"datatype\": \"anyURI\"
            },
            {
                \"titles\": \"specifikaceSlužby\",
                \"dc:description\": \"Odkaz na specifikaci datové služby.\",
                \"datatype\": \"anyURI\"
            }
        ]
    }
}""";
    <http://plugins.linkedpipes.com/ontology/e-textHolder#contentControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
