<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779115/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779115/1>
    a <http://plugins.linkedpipes.com/ontology/t-mustache#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#addFirstFlag> true;
    <http://plugins.linkedpipes.com/ontology/t-mustache#addFirstFlagControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#class> "http://localhost/temp/Seznam";
    <http://plugins.linkedpipes.com/ontology/t-mustache#classControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#escapeForJson> true;
    <http://plugins.linkedpipes.com/ontology/t-mustache#escapeForJsonControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#template> """{{!
  PREFIX mustache: <http://plugins.linkedpipes.com/ontology/t-mustache#>
  PREFIX dcat: <http://www.w3.org/ns/dcat#>
  PREFIX dcterms: <http://purl.org/dc/terms/>
  PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
  PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  PREFIX gr: <http://purl.org/goodrelations/v1#>
  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  PREFIX local: <http://localhost/temp/>
}}
{
\"_id\" : \"local_catalogs\",
\"jsonld\": [
{{#local:catalog}}
{{^mustache:first}},{{/mustache:first}}
    {
      \"@id\": \"{{{@id}}}\",
      \"@type\": \"{{{local:type}}}\",
{{#dcterms:publisher}}
      \"http://purl.org/dc/terms/publisher\": {\"@id\": \"{{{@id}}}\"},
{{/dcterms:publisher}}
      \"http://purl.org/dc/terms/title\": [
{{#local:cs}}
{
\"@value\" : \"{{{.}}}\",
\"@language\": \"cs\"
}{{#local:en}},{{/local:en}}
{{/local:cs}}
{{#local:en}}
{
\"@value\" : \"{{{.}}}\",
\"@language\": \"en\"
}
{{/local:en}}],
{{#dcat:contactPoint}}
      \"http://www.w3.org/ns/dcat#contactPoint\": {
{{#vcard:hasEmail}}
      \"http://xmlns.com/foaf/0.1/email\": \"{{{@id}}}\"{{#vcard:fn}},{{/vcard:fn}}
{{/vcard:hasEmail}}
{{#vcard:fn}}
      \"http://xmlns.com/foaf/0.1/name\": {
              \"@value\": \"{{{.}}}\",
              \"@language\": \"cs\"
       }
{{/vcard:fn}}
      },
{{/dcat:contactPoint}}
{{#foaf:homepage}}
      \"http://xmlns.com/foaf/0.1/homepage\": {
\"@id\": \"{{{@id}}}\"
},
{{/foaf:homepage}}
{{#dcat:endpointURL}}
      \"http://www.w3.org/ns/dcat#endpointURL\": {
\"@id\": \"{{{@id}}}\"
}
{{/dcat:endpointURL}}
}
{{/local:catalog}}
]
}""";
    <http://plugins.linkedpipes.com/ontology/t-mustache#templateControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779119/configuration> {
