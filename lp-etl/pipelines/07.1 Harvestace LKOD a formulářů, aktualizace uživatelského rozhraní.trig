  PREFIX foaf: <http://xmlns.com/foaf/0.1/>
  PREFIX local:   <http://localhost/temp/>
}}
{
\"_id\" : \"initial_data_cache\",
\"jsonld\": [
{}
{{#local:publishers}}
,
{
\"@id\" : \"{{{@id}}}\",
\"http://xmlns.com/foaf/0.1/name\" : [
{{#local:cs}}
{
\"@value\" : \"{{{.}}}\",
\"@language\": \"cs\"
}{{#local:en}},{{/local:en}}
{{/local:cs}}
{{#local:en}}
{
\"@value\" : \"{{{.}}}\",
\"@language\": \"en\"
}
{{/local:en}}
]
}
{{/local:publishers}}

{{#local:themes}}
,{
\"@id\": \"{{{@id}}}\",
\"http://www.w3.org/2004/02/skos/core#prefLabel\" : [
{
\"@value\" : \"{{{local:cs}}}\",
\"@language\": \"cs\"
},
{
\"@value\" : \"{{{local:en}}}\",
\"@language\": \"en\"
}
]
}
{{/local:themes}}
]
}""";
    <http://plugins.linkedpipes.com/ontology/t-mustache#templateControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779121/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779121/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX localhost: <http://localhost/>
PREFIX ss: <http://plugins.linkedpipes.com/ontology/t-sparqlSelectMultiple#> 
PREFIX loc: <http://www.w3.org/2007/uwa/context/location.owl#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>

CONSTRUCT { 
?configiri a ss:Configuration ;
    ss:query ?query ;
    ss:fileName ?filename .
} 
WHERE 
{ 
  {SELECT DISTINCT ?catalog WHERE {?catalog dcat:dataset [] . }}

BIND(CONCAT(\"\"\"
PREFIX dcat: <http://www.w3.org/ns/dcat#>
SELECT ?dataset
WHERE {
<\"\"\",STR(?catalog),\"\"\"> dcat:dataset ?dataset .
}
\"\"\") as ?query)

BIND(CONCAT(REPLACE(STR(?catalog),\"[:/\\\\.]\",\"_\"),\".csv\") as ?filename)
BIND(UUID() as ?configiri)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

