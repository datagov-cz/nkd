<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779b6b2-9eaa/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779b6b2-9eaa/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"filter.json\" ;
   local:publishers ?publisher .

  ?publisher local:původce-vdf true .
  
}
WHERE {
    ?dataset a dcat:Dataset;
             dcterms:creator ?publisher .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779c8b1-b179/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779c8b1-b179/1>
