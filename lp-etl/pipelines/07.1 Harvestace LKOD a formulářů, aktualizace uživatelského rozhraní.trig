<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779332/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779332/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"publisher_keywords_en.json\" ;
   local:entry ?entryID.
?entryID a local:Entry ;
   rdf:value ?počet_poskytovatelů ;
   <urn:keyword> ?kwstring ;
   <urn:keyword_lang> ?lang .
}
WHERE {
{
SELECT ?keyword (count (distinct ?poskytovatel ) as ?počet_poskytovatelů)
WHERE 
{
?datova_sada a dcat:Dataset ; 
    dcterms:publisher ?poskytovatel ;
    ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> ;
    dcat:keyword ?keyword .
}
GROUP BY ?keyword
#HAVING (?počet_poskytovatelů > 1)
}
BIND(IRI(CONCAT(\"http://localhost/temp/\", LANG(?keyword), \"/\", ENCODE_FOR_URI(STR(?keyword)))) as ?entryID)
BIND(STR(?keyword) as ?kwstring)
BIND(LANG(?keyword) as ?lang)
  FILTER(LANG(?keyword) = \"en\")
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779339/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779339/1>
    a <http://plugins.linkedpipes.com/ontology/t-chunkedToGraph#Configuration> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177934/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177934/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

PREFIX status: <http://purl.org/adms/status/> 
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
?dataset adms:status status:Withdrawn ;
    nkod:zrušovatel ?ovm .  
}
WHERE { 
?dataset a dcat:Dataset ;
    adms:status status:Withdrawn .
      
# chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
[] chunked:fileName ?filename .
[] nkod:jméno-souboru ?filename ;
   nkod:id-datové-zprávy ?iddz ;
   nkod:datová-schránka-poskytovatele ?ds ;
   nkod:datová-zpráva-přijata ?rmodified .
  
?ds ^ds:datová-schránka ?ovm .
?ovm gr:legalName ?pname ;
     skos:notation ?ovmid .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779348/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779348/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcatap: <http://data.europa.eu/r5r/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>

PREFIX mustache: <http://plugins.linkedpipes.com/ontology/t-mustache#>
PREFIX temp: <urn:>
PREFIX vdf: <https://data.gov.cz/slovník/nkod/vdf/>

CONSTRUCT { 
<urn:root> a temp:Root ;
    mustache:fileName \"nkod_dump_for_solr.json\" ;
    temp:dataset ?dataset  .

?dataset
    temp:title_cs ?title_cs ;
    temp:title_cs_sort ?title_cs ;
    temp:title_en ?title_en ;
    temp:title_en_sort ?title_en ;
    temp:description_cs ?description_cs ;
    temp:description_en ?description_en ;
    temp:issued ?issuedStr ;
    temp:modified ?modifiedStr ;
    temp:accrualPeriodicity ?accrualPeriodicityStr ;
    temp:publisher ?publisherStr ;
    temp:keywords_cs ?keywordCsEntity ;
    temp:keywords_en ?keywordEnEntity ;
    temp:themes ?theme ;        
    temp:file_type ?file_type ;
    temp:temporalStart ?temporalStartStr ;
    temp:temporalEnd ?temporalEndStr ;
    temp:spatial ?spatial ;
    temp:vdf_public_data ?vdf_public_data ;
    temp:vdf_codelist ?vdf_číselník ;
    dcat:inSeries ?higherDataset ;
    temp:with_data_service ?with_data_service ;
    dcatap:hvdCategory ?hvdCategory ;
    dcatap:applicableLegislation ?applicableLegislation .

?keywordCsEntity  temp:value ?keywordStr_cs .
?keywordEnEntity  temp:value ?keywordStr_en .

} 
WHERE { 
?dataset a dcat:Dataset .
  BIND(EXISTS { ?dataset a vdf:datová-sada-publikující-veřejné-údaje } AS ?vdf_public_data)
  BIND(EXISTS { ?dataset a vdf:číselník } AS ?vdf_číselník)
  BIND(EXISTS { ?dataset dcat:distribution/dcat:accessService []} AS ?with_data_service)

  OPTIONAL {
    ?dataset dcterms:title ?title_cs .
    FILTER(LANGMATCHES(LANG(?title_cs), \"cs\"))
  }
  OPTIONAL {
    ?dataset dcterms:title ?title_en .
    FILTER(LANGMATCHES(LANG(?title_en), \"en\"))
  }
  OPTIONAL {
    ?dataset dcterms:description ?description_cs .
    FILTER(LANGMATCHES(LANG(?description_cs), \"cs\"))
  }
  OPTIONAL {
    ?dataset dcterms:description ?description_en .
    FILTER(LANGMATCHES(LANG(?description_en), \"en\"))
  }
  OPTIONAL { ?dataset dcterms:issued ?issued . }
  OPTIONAL { ?dataset dcterms:modified ?modified . }
  OPTIONAL { ?dataset dcterms:accrualPeriodicity ?accrualPeriodicity . }
  OPTIONAL { ?dataset dcterms:publisher ?publisher . }
  OPTIONAL {
    ?dataset dcat:keyword ?keyword_cs .
    FILTER(LANGMATCHES(LANG(?keyword_cs), \"cs\"))
    BIND(STR(?keyword_cs) as ?keywordStr_cs)
    BIND(IRI(CONCAT(STR(?dataset), ENCODE_FOR_URI(?keywordStr_cs))) AS ?keywordCsEntity)
  }
  OPTIONAL {
    ?dataset dcat:keyword ?keyword_en .
    FILTER(LANGMATCHES(LANG(?keyword_en), \"en\"))
    BIND(STR(?keyword_en) as ?keywordStr_en)
    BIND(IRI(CONCAT(STR(?dataset), ENCODE_FOR_URI(?keywordStr_en))) AS ?keywordEnEntity)
  }
  OPTIONAL { 
    ?dataset dcat:theme ?theme . 
    FILTER NOT EXISTS {
      ?theme skos:inScheme <https://slovník.gov.cz/základní/pojem/typ-vlastnosti> .
    }
    FILTER NOT EXISTS {
      ?theme skos:inScheme <https://slovník.gov.cz/základní/pojem/typ-vztahu> .
    }
  }
  OPTIONAL { 
    ?dataset dcat:distribution ?distribution . 
    ?distribution a dcat:Distribution ;
                  dcterms:format ?file_type .
  }
  OPTIONAL {
    ?dataset dcterms:temporal ?temporal .
    ?temporal dcat:startDate ?temporalStart .
    FILTER(REGEX(STR(?temporalStart), \"^[0-9]{4}-[0-9]{2}-[0-9]{2}\"))
  }
  OPTIONAL {
    ?dataset dcterms:temporal ?temporal .
    ?temporal dcat:endDate ?temporalEnd .
    FILTER(REGEX(STR(?temporalEnd), \"^[0-9]{4}-[0-9]{2}-[0-9]{2}\"))
  }
  OPTIONAL {?dataset dcterms:spatial ?spatial . }
  OPTIONAL {?dataset dcat:inSeries ?higherDataset . }
  OPTIONAL {?dataset dcatap:hvdCategory ?hvdCategory . }
  OPTIONAL {?dataset dcatap:applicableLegislation ?applicableLegislation . }
  
  BIND(IF(CONTAINS(STR(?temporalStart),\"+\"),STRBEFORE(STR(?temporalStart), \"+\"), STR(?temporalStart)) AS ?temporalStartStr)
  BIND(IF(CONTAINS(STR(?temporalEnd),\"+\"),STRBEFORE(STR(?temporalEnd), \"+\"), STR(?temporalEnd)) AS ?temporalEndStr)
  BIND(STR(?modified) as ?modifiedStr)
  BIND(STR(?accrualPeriodicity) as ?accrualPeriodicityStr)
  BIND(STR(?issued) as ?issuedStr)
  BIND(STR(?publisher) as ?publisherStr)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779355/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779355/1>
    a <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#commitSize> 1;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#commitSizeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#filePredicate> <https://etl.linkedpipes.com/plugins/t-filestochunked/fileName>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#filePredicateControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#fileReference> false;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#fileReferenceControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#mimeType> "text/turtle";
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#mimeTypeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#softFail> true;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-filesToRdfChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779358/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779358/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX srtfl: <http://plugins.linkedpipes.com/ontology/t-sparqlConstructToFileList#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>

CONSTRUCT 
{
<https://localhost/nkod-task> a srtfl:Task ;
    srtfl:fileName \"nkod.trig\" ;
    srtfl:fileFormat \"application/trig\" ;
    srtfl:hasTaskQuery ?tqIRI .

?tqIRI a srtfl:TaskQuery ;
    srtfl:outputGraph ?dataset ;
    srtfl:query ?query .
} 

WHERE 
{ 
?dataset a dcat:Dataset .

BIND(UUID() as ?tqIRI)
  #Dataset is generated as a constant becasue using VALUES has way longer execution time
BIND(CONCAT(\"\"\"
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX dcatap: <http://data.europa.eu/r5r/>
PREFIX adms: <http://www.w3.org/ns/adms#>

PREFIX tz: <https://data.gov.cz/slovník/nkod/typ-datové-sady-dle-zdroje/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>

CONSTRUCT {
?catalog dcat:dataset <\"\"\",STR(?dataset),\"\"\"> ;
         dcat:record ?record.

<\"\"\",STR(?dataset),\"\"\"> a dcat:Dataset, ?typZáznamu ;
    dcterms:title ?title ;
    dcterms:description ?description ;
	dcat:theme ?theme ;
	dcterms:accrualPeriodicity ?accrualPeriodicity ;
	dcat:keyword ?keyword ;
    dcterms:spatial ?spatial ;
    dcterms:temporal ?temporal ;
	dcterms:accessRights ?accessRights ;
	dcat:contactPoint ?cp ;
	foaf:page ?page ;
    dcterms:conformsTo ?conformsTo ;
    dcat:spatialResolutionInMeters ?spatialResolution ;
    dcat:temporalResolution ?temporalResolution ;
    dcat:inSeries ?topDataset ;
    dcat:seriesMember ?lowerDataset ;
    dcterms:publisher ?publisher ;
	dcterms:identifier ?identifier ;
	dcat:distribution ?distribution ;
    dcterms:creator ?původce ;
    dcatap:applicableLegislation ?datasetApplicableLegislation ;
    dcatap:hvdCategory ?datasethvdCategory ;
    adms:identifier ?datasetId .
    
?datasetId a adms:Identifier ;
    skos:notation ?datasetIdNotation ;
    dcterms:creator ?datasetIdCreator .

?cp a ?cptype; 
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .

?publisher a foaf:Agent; 
	foaf:name ?name .

?temporal a dcterms:PeriodOfTime; 
    dcat:startDate ?startDate ;
    dcat:endDate ?endDate .

?theme skos:inScheme ?scheme .

?distribution a dcat:Distribution ;
    dcat:downloadURL ?ddURL ;
    dcat:accessURL ?daURL ;
    dcterms:format ?dformat ;
	dcat:mediaType ?dmimeType ;
	dcterms:conformsTo ?dconformsTo ;
    dcat:compressFormat ?dcompressFormat ;
    dcat:packageFormat ?dpackageFormat ;
    dcterms:title ?dtitle ;
	dcterms:license ?tou ;
	dcatap:applicableLegislation ?distributionApplicableLegislation ;
	#pro ukázku toho, co za špatný media typ bylo zaregistrováno
    nkod:mediaType ?LmimeType .

?distribution pu:specifikace ?tou .

?tou a pu:Specifikace ;
    pu:autorské-dílo ?touGeneral ;
	pu:databáze-jako-autorské-dílo ?touDatabase ;
    pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
	pu:osobní-údaje ?touPersonalData ;
	pu:autor ?touGeneralAuthor ;
	pu:autor-databáze ?touDatabaselAuthor ;
    skos:exactMatch ?touExactMatch ;
    skos:closeMatch ?touCloseMatch ;
    skos:broadMatch ?touBroadMatch ; 
    skos:narrowMatch ?touNarrowMatch .

?distribution dcat:accessService ?dataService . 
  
?dataService a dcat:DataService ;
    dcterms:title ?sTitle ;
    dcterms:conformsTo ?sConformsTo ;
    dcat:endpointURL ?sEndpointURL ;
    dcat:endpointDescription ?sEndpointDescription ;
    dcat:servesDataset <\"\"\",STR(?dataset),\"\"\"> ;
    dcatap:applicableLegislation ?dataServiceApplicableLegislation ;
    dcatap:hvdCategory ?dataServicehvdCategory ;
    foaf:page ?dataServiceDocumentation ;
    dcat:contactPoint ?dscp ;
    adms:identifier ?serviceId .
    
?serviceId skos:notation ?serviceIdNotation ;
    dcterms:creator ?serviceIdCreator .

?dscp a ?dscptype; 
    vcard:fn ?dscpfn ;
    vcard:hasEmail ?dscpemail .

?record a dcat:CatalogRecord;
    foaf:primaryTopic <\"\"\",STR(?dataset),\"\"\"> ;
    dcterms:language ?rlanguage ;
    dcterms:conformsTo ?rconformsTo ;
    dcterms:source ?rsource .
}
WHERE {
  {
	<\"\"\",STR(?dataset),\"\"\"> a dcat:Dataset, ?typZáznamu ;
        dcterms:title ?title ;
        dcterms:description ?description .
    FILTER(?typZáznamu != dcat:Dataset)
  } UNION { 
    <\"\"\",STR(?dataset),\"\"\"> dcat:distribution ?distribution .

    ?distribution a dcat:Distribution ;
        dcat:accessURL ?daURL .

    OPTIONAL { 
        ?distribution pu:specifikace ?tou .
        ?tou a pu:Specifikace ;
            pu:autorské-dílo ?touGeneral ;
            pu:databáze-jako-autorské-dílo ?touDatabase ;
            pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
            pu:osobní-údaje ?touPersonalData .

        OPTIONAL { ?tou pu:autor ?touGeneralAuthor . }
        OPTIONAL { ?tou pu:autor-databáze ?touDatabaselAuthor . }
        OPTIONAL { ?tou skos:exactMatch ?touExactMatch . }
        OPTIONAL { ?tou skos:closeMatch ?touCloseMatch . }
        OPTIONAL { ?tou skos:broadMatch ?touBroadMatch . }
        OPTIONAL { ?tou skos:narrowMatch ?touNarrowMatch . }
    }

    OPTIONAL { ?distribution dcat:downloadURL ?ddURL . }
    OPTIONAL { ?distribution dcterms:description ?ddescription . }
    OPTIONAL { ?distribution dcterms:format ?dformat . }
    OPTIONAL { ?distribution dcat:mediaType ?dmimeType . }
    OPTIONAL { ?distribution nkod:mediaType ?LmimeType . }
    OPTIONAL { ?distribution dcterms:conformsTo ?dconformsTo . }
	OPTIONAL { ?distribution dcatap:applicableLegislation ?distributionApplicableLegislation . }
    OPTIONAL { ?distribution dcat:compressFormat ?dcompressFormat . }
    OPTIONAL { ?distribution dcat:packageFormat ?dpackageFormat . }
    OPTIONAL { ?distribution dcterms:title ?dtitle . }
    OPTIONAL { 
        ?distribution dcat:accessService ?dataService . 
        ?dataService a dcat:DataService ;
                    dcterms:title ?sTitle ;
                    dcat:endpointURL ?sEndpointURL .
        OPTIONAL { ?dataService dcat:endpointDescription ?sEndpointDescription .}
        OPTIONAL { ?dataService dcatap:applicableLegislation ?dataServiceApplicableLegislation .}
        OPTIONAL { ?dataService dcatap:hvdCategory ?dataServicehvdCategory . }
        OPTIONAL { ?dataService foaf:page ?dataServiceDocumentation . }
        OPTIONAL { ?dataService dcterms:conformsTo ?sConformsTo . }
        OPTIONAL { ?dataService dcat:contactPoint ?dscp . 
            ?dscp a ?dscptype.
            OPTIONAL { ?dscp vcard:fn ?dscpfn . }
            OPTIONAL { ?dscp vcard:hasEmail ?dscpemail . }
        }
        OPTIONAL {
            ?dataService adms:identifier ?serviceId .
            ?serviceId skos:notation ?serviceIdNotation ;
                dcterms:creator ?serviceIdCreator .
        }
    }
  } UNION { ?catalog dcat:dataset <\"\"\",STR(?dataset),\"\"\"> . 
  } UNION {
    ?catalog dcat:dataset <\"\"\",STR(?dataset),\"\"\"> ;
            dcat:record ?record .

    ?record a dcat:CatalogRecord;
                foaf:primaryTopic <\"\"\",STR(?dataset),\"\"\"> .
    OPTIONAL { ?record dcterms:language ?rlanguage . }
    OPTIONAL { ?record dcterms:conformsTo ?rconformsTo . }
    OPTIONAL { ?record dcterms:source ?rsource . }
  } UNION {
<\"\"\",STR(?dataset),\"\"\"> dcat:seriesMember ?lowerDataset .
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:accrualPeriodicity ?accrualPeriodicity .   } UNION { <\"\"\",STR(?dataset),\"\"\"> dcat:keyword ?keyword . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:spatial ?spatial . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> foaf:page ?page . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:creator ?původce .
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:conformsTo ?conformsTo . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcat:spatialResolutionInMeters ?spatialResolution . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcat:temporalResolution ?temporalResolution . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcat:inSeries ?topDataset . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:identifier ?identifier . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:accessRights ?accessRights . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcatap:applicableLegislation ?datasetApplicableLegislation . 
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcatap:hvdCategory ?datasethvdCategory .
  } UNION { <\"\"\",STR(?dataset),\"\"\"> adms:identifier ?datasetId .
    ?datasetId skos:notation ?datasetIdNotation ;
        dcterms:creator ?datasetIdCreator .
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcat:theme ?theme .
	OPTIONAL { ?theme skos:inScheme ?scheme . }
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcterms:temporal ?temporal . 
    OPTIONAL { ?temporal dcat:startDate ?startDate . }
    OPTIONAL { ?temporal dcat:endDate ?endDate . }
  } UNION { <\"\"\",STR(?dataset),\"\"\"> dcat:contactPoint ?cp . 
?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { ?cp vcard:hasEmail ?cpemail . }
  } UNION { 
    <\"\"\",STR(?dataset),\"\"\"> dcterms:publisher ?publisher . 
	
    ?publisher a foaf:Agent; 
        foaf:name ?name .
    }
}
\"\"\") as ?query)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177937/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177937/1>
    a <http://plugins.linkedpipes.com/ontology/t-chunkedToGraph#Configuration> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779371/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779371/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

CONSTRUCT { [] a <http://localhost/temp/Message>; 
 <http://localhost/temp/text> ?finaltext ;
 <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"configuration.json\" .
} 
WHERE {  
  {
    SELECT (COUNT(DISTINCT ?publisher) as ?Poskytovatelů) (SUM(?PočetDatovýchSad) as ?DatovýchSad) (SUM(?PočetDistribucí) as ?Distribucí) 
    WHERE {
  { 
  SELECT ?publisher (count(distinct ?dataset) as ?PočetDatovýchSad) (count(distinct ?distribution) as ?PočetDistribucí)
	WHERE { 

  ?dataset a dcat:Dataset;
           dcterms:publisher ?publisher ;
          ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> .
          
  OPTIONAL {?dataset dcat:distribution ?distribution . }
  #?publisher foaf:name ?Poskytovatel.
  
  }
  GROUP BY ?publisher
  ORDER BY DESC(?PočetDatovýchSad) 
  }
    #BIND(CONCAT(STR(?Poskytovatel), \" má \", STR(?PočetDatovýchSad), \" datových sad. \\n\") as ?line)
  }
  }
  
  BIND(CONCAT(\"Testovací verze NKOD@UPAAS k \", STR(NOW()), \" obsahuje \", STR(?DatovýchSad), \" datových sad a \", STR(?Distribucí), \" distribucí od \", STR(?Poskytovatelů), \" poskytovatelů.\") as ?finaltext)
 
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779372/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779372/1>
    a <http://plugins.linkedpipes.com/ontology/t-mustache#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#addFirstFlag> false;
    <http://plugins.linkedpipes.com/ontology/t-mustache#addFirstFlagControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#class> "http://localhost/temp/Message";
    <http://plugins.linkedpipes.com/ontology/t-mustache#classControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#escapeForJson> false;
    <http://plugins.linkedpipes.com/ontology/t-mustache#escapeForJsonControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-mustache#template> """{{!
  PREFIX mustache: <http://plugins.linkedpipes.com/ontology/t-mustache#>
  PREFIX local:   <http://localhost/temp/>
}}
{
\"text\" : \"{{{local:text}}}\"
}""";
    <http://plugins.linkedpipes.com/ontology/t-mustache#templateControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

