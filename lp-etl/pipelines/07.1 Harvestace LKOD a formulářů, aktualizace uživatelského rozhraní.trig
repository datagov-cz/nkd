<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317793/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317793/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
INSERT { 
  ?theme skos:inScheme ?scheme .
} 
WHERE 
{
  {
    ?dataset dcat:theme ?theme .
    FILTER(STRSTARTS(STR(?theme), \"http://eurovoc.europa.eu/\"))
    BIND(<http://eurovoc.europa.eu/> AS ?scheme)
  }
  UNION
  {
    ?dataset dcat:theme ?theme .
    FILTER(STRSTARTS(STR(?theme), \"http://publications.europa.eu/resource/authority/data-theme/\"))
    BIND(<http://publications.europa.eu/resource/authority/data-theme> AS ?scheme)
  }  
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779317/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779317/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
INSERT { 
  <https://data.gov.cz/zdroj/katalog/NKOD> a dcat:Catalog ;
    dcat:record ?record ;
    dcat:dataset ?dataset .
} 
WHERE 
{ 
  ?record a dcat:CatalogRecord;
          foaf:primaryTopic ?dataset .
  ?dataset a dcat:Dataset ;
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
