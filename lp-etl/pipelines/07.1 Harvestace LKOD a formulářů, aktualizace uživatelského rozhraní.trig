<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779177/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779177/1>
    a <http://plugins.linkedpipes.com/ontology/t-rdfToWrappedJsonLdChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-rdfToWrappedJsonLdChunked#idResourceType>
      <http://www.w3.org/ns/dcat#Dataset>;
    <http://plugins.linkedpipes.com/ontology/t-rdfToWrappedJsonLdChunked#idResourceTypeControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-rdfToWrappedJsonLdChunked#template> "{ \"_id\":\"{{ID}}\", \"jsonld\":{{JSONLD}} }";
    <http://plugins.linkedpipes.com/ontology/t-rdfToWrappedJsonLdChunked#templateControl>
      <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779178/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779178/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#fileName> "distribuce.csv";
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#fileNameControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#> 
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>

SELECT ?datová_sada ?distribuce ?typ ?název ?autorskéDílo ?databázeAutorskéDílo ?zvláštníPrávoPořizovateleDatabáze ?osobníÚdaje ?přístupovéUrl ?formátSouboru ?mediaTypeSouboru ?odkazNaSchémaSouboru ?popisPřístupovéhoBoduSlužby ?specifikaceSlužby
WHERE 
{
  ?datová_sada a dcat:Dataset ;
  ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> .
  
  ?datová_sada dcat:distribution ?distribuce .

  ?distribuce a dcat:Distribution .

  OPTIONAL { ?distribuce dcat:accessSerivce ?služba .
    ?služba dcterms:title ?název_služby .
    BIND(STR(?název_služby) AS ?názevS)
    FILTER(LANG(?název_služby) = \"cs\")    
  }

  OPTIONAL { ?distribuce dcat:accessSerivce ?služba .
    ?služba dcat:endpointDescription ?popisPřístupovéhoBoduSlužby .
  }

  OPTIONAL { ?distribuce dcat:accessSerivce ?služba .
    ?služba dcterms:conformsTo ?specifikaceSlužby .
  }

  OPTIONAL { ?distribuce dcterms:title ?nazev_rdf .
    BIND(STR(?nazev_rdf) AS ?názevF)
    FILTER(LANG(?nazev_rdf) = \"cs\")    
  }
  BIND(COALESCE(?názevF, ?názevS) AS ?název)
  BIND(IF(BOUND(?služba), \"Služba\", \"Soubor\") AS ?typ)

  OPTIONAL { ?distribuce dcat:accessURL ?accessURL_rdf .
    BIND(STR(?accessURL_rdf) AS ?přístupovéUrl)
  }

  OPTIONAL { ?distribuce dcterms:conformsTo ?schema_rdf .
    BIND(STR(?schema_rdf) AS ?odkazNaSchémaSouboru)
  }

  OPTIONAL { ?distribuce dcterms:format ?format_rdf .    
    ?format_rdf skos:prefLabel ?format_label . 
    BIND(STR(?format_label) as ?formátSouboru)
    FILTER(LANG(?format_label) = \"en\")
  }

  OPTIONAL{ ?distribuce dcat:mediaType ?mt_rdf . 
    BIND(STRAFTER(STR(?mt_rdf), \"http://www.iana.org/assignments/media-types/\") AS ?mediaTypeSouboru)
  }

  OPTIONAL { 
    ?distribuce <https://data.gov.cz/slovník/podmínky-užití/specifikace> ?Specifikace .

    ?Specifikace <https://data.gov.cz/slovník/podmínky-užití/autorské-dílo> ?AD_rdf ;
                 <https://data.gov.cz/slovník/podmínky-užití/databáze-jako-autorské-dílo> ?DAD_rdf ;
                 <https://data.gov.cz/slovník/podmínky-užití/databáze-chráněná-zvláštními-právy> ?ZPPD_rdf .
    BIND(STR(?AD_rdf) AS ?autorskéDílo)
    BIND(STR(?DAD_rdf) AS ?databázeAutorskéDílo)
    BIND(STR(?ZPPD_rdf) AS ?zvláštníPrávoPořizovateleDatabáze)

    OPTIONAL {?Specifikace <https://data.gov.cz/slovník/podmínky-užití/osobní-údaje> ?OU_rdf .
      BIND(STR(?OU_rdf) AS ?osobníÚdaje)
    }

  } 
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177918/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-000116110389317791611038931779161103893177918/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX adms: <http://www.w3.org/ns/adms#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

PREFIX status: <http://purl.org/adms/status/> 
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
?dataset_candidate nkod:issued ?rmodified ;
                   nkod:issuer ?ovm .
}
WHERE { 
?dataset a dcat:Dataset .
      
# chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
[] chunked:fileName ?filename .
[] nkod:jméno-souboru ?filename ;
   nkod:id-datové-zprávy ?iddz ;
   nkod:datová-schránka-poskytovatele ?ds ;
   nkod:datová-zpráva-přijata ?rmodified .
  
?ds ^ds:datová-schránka ?ovm .
?ovm gr:legalName ?pname ;
     skos:notation ?ovmid .
  
  BIND (IRI(CONCAT(\"https://data.gov.cz/zdroj/datové-sady/\", ?ovmid, \"/\", ?iddz)) as ?dataset_candidate)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779181/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779181/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"filter.json\" ;
   local:publishers ?publisher .

  ?publisher local:cs ?csstring.
  ?publisher local:en ?enstring.
  
}
WHERE {
  ?dataset a dcat:Dataset;
  ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> ;
  dcterms:publisher ?publisher .
  
  OPTIONAL {
    ?publisher foaf:name ?cs_label .
    FILTER(langMatches(LANG(?cs_label), \"cs\"))
    BIND(STR(?cs_label) as ?csstring)
  }
  
  OPTIONAL {
    ?publisher foaf:name ?en_label .
    FILTER(langMatches(LANG(?en_label), \"en\"))
    BIND(STR(?en_label) as ?enstring)
  }
  
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779182/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779182/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#fileName> "datové-sady.csv";
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#fileNameControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#query> """PREFIX dcatap: <http://data.europa.eu/r5r/>
PREFIX dcat: <http://www.w3.org/ns/dcat#> 
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX dcterm: <http://purl.org/dc/terms/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT ?datová_sada ?název ?popis ?poskytovatel_IRI ?poskytovatel ?klíčová_slova ?prostorové_pokrytí ?téma_IRI ?téma ?periodicita_aktualizace_IRI ?periodicita_aktualizace ?je_součástí_IRI ?právní_předpis ?kategorie_hvd_IRI ?kategorie_hvd_název
WHERE 
{
?datová_sada a dcat:Dataset ;
          dcterms:publisher ?poskytovatel_IRI ;
          ^dcat:dataset <https://data.gov.cz/zdroj/katalog/NKOD> .

    OPTIONAL{ ?datová_sada dcterms:title ?nazev_rdf .
      BIND(STR(?nazev_rdf) AS ?název)
      FILTER(LANG(?nazev_rdf) = \"cs\")    
    }

    OPTIONAL{ ?datová_sada dcterms:description ?popis_rdf .
      BIND(STR(?popis_rdf) AS ?popis)
      FILTER(LANG(?popis_rdf) = \"cs\")   
    }
    
    OPTIONAL{ ?datová_sada dcat:keyword ?kw_rdf .
      BIND(STR(?kw_rdf) AS ?klíčová_slova)
      FILTER(LANG(?kw_rdf) = \"cs\")
    }
  
  	OPTIONAL {
    	?datová_sada dcat:inSeries ?je_součástí_IRI .
    }
    
    OPTIONAL{ ?datová_sada dcterms:spatial ?spatial_rdf .
      BIND(STR(?spatial_rdf) AS ?prostorové_pokrytí)
    }
    
    OPTIONAL{ ?datová_sada dcat:theme ?téma_IRI . 
        OPTIONAL {
      ?téma_IRI skos:prefLabel ?theme_label .
      
      BIND(STR(?theme_label) as ?téma)
      FILTER(LANG(?theme_label) = \"cs\")
      }
      
    }
    
    OPTIONAL{ ?datová_sada dcterms:accrualPeriodicity ?periodicita_aktualizace_IRI . 
      OPTIONAL {
          ?periodicita_aktualizace_IRI skos:prefLabel ?periodicity_label.  
    
      BIND(STR(?periodicity_label) as ?periodicita_aktualizace)
  		FILTER(LANG(?periodicity_label) = \"cs\")
      }
    }

    OPTIONAL{ ?datová_sada dcatap:applicableLegislation ?právní_předpis . }
    OPTIONAL{ 
    	?datová_sada dcatap:hvdCategory ?kategorie_hvd_IRI . 
    	?kategorie_hvd_IRI skos:prefLabel ?hvd_label .
      
      	BIND(STR(?hvd_label) as ?kategorie_hvd_název)
      	FILTER(LANG(?hvd_label) = \"cs\")
  	}

  ?poskytovatel_IRI foaf:name ?publisherName_rdf .
    
    BIND(STR(?publisherName_rdf) AS ?poskytovatel)
    FILTER(LANG(?publisherName_rdf) = \"cs\")
   
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791ce6-8f9b/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791ce6-8f9b/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX tds: <https://data.gov.cz/slovník/datové-schránky/typ-datové-schránky/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX pojem: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>

CONSTRUCT { 
?ovm gr:legalName ?ovmNázev;
  skos:notation ?ovmID ;
  ds:datová-schránka ?ds .
} 
WHERE { 
?ovm pojem:má-datovou-schránku-orgánu-veřejné-moci ?dsIRI ;
  		pojem:má-identifikátor-orgánu-veřejné-moci ?ovmID ;
  		pojem:má-název-orgánu-veřejné-moci ?ovmNázev .
  
  	 ?dsIRI pojem:má-identifikátor-datové-schránky ?dsID .
  BIND(IRI(CONCAT(\"https://data.gov.cz/zdroj/datové-schránky/\", ?dsID)) AS ?ds)
}
""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791dc8-852b/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791dc8-852b/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

INSERT {
  ?publisher local:původce-vdf false .
}
WHERE {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"filter.json\" ;
   local:publishers ?publisher .

  FILTER NOT EXISTS {?publisher local:původce-vdf true .}
  
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791fa4-b8d5/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317791fa4-b8d5/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat:       <http://www.w3.org/ns/dcat#>
PREFIX rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX local:       <http://localhost/temp/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

CONSTRUCT {
<http://localhost/resource/root> a local:Root;
   <http://plugins.linkedpipes.com/ontology/t-mustache#fileName> \"filter.json\" ;
   local:publishers ?publisher .

  ?publisher local:poskytovatel-vdf true .
  
}
WHERE {
    ?dataset a dcat:Dataset, ?type ;
             dcterms:publisher ?publisher .
  FILTER (?type IN (
      <https://data.gov.cz/slovník/nkod/vdf/datová-sada-publikující-veřejné-údaje>,
      <https://data.gov.cz/slovník/nkod/vdf/číselník>
    )
  )
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

