    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#defaultGraphControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#encodeRdf> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#encodeRdfControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#endpoint> "http://localhost:8891/sparql";
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#endpointControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#handleInvalidData> false;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#handleInvalidDataControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#headerAcceptControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#passwordControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#query> """PREFIX pojmy: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>

CONSTRUCT {
    ?údaj a pojmy:údaj, ?typ ;
        pojmy:iri-datové-sady-publikující-veřejný-údaj ?ds ;
        pojmy:je-kódovaný-číselníkem ?číselník .
    ?číselník pojmy:iri-číselníku-v-nkod ?číselník_v_nkod .
}
WHERE {
    ?údaj a pojmy:údaj, ?typ .
    OPTIONAL {
        ?údaj pojmy:iri-datové-sady-publikující-veřejný-údaj ?ds .
    }
    OPTIONAL {
        ?údaj pojmy:je-kódovaný-číselníkem ?číselník .
        OPTIONAL {
            ?číselník pojmy:iri-číselníku-v-nkod ?číselník_v_nkod .
        }
    }
}""";
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpoint#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
