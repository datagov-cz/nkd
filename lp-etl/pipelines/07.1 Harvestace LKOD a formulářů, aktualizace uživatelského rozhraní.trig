}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779160/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779160/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#createNewChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX schema: <http://schema.org/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX dcatap: <http://data.europa.eu/r5r/>

PREFIX tz: <https://data.gov.cz/slovník/nkod/typ-datové-sady-dle-zdroje/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX pu: <https://data.gov.cz/slovník/podmínky-užití/>

PREFIX chunked: <https://etl.linkedpipes.com/plugins/t-filestochunked/>

CONSTRUCT {
  ?catalog dcat:dataset ?dataset_new .

  ?dataset_new a ?datasetType, tz:SPARQL, tz:LKOD ;
    dcterms:title ?title ;
    dcterms:description ?description ;
    dcat:theme ?theme ;
    dcterms:accrualPeriodicity ?accrualPeriodicity ;
    dcat:keyword ?keyword ;
    dcterms:spatial ?spatial ;
    dcterms:temporal ?temporal_new ;
    dcat:contactPoint ?cp_new ;
    foaf:page ?page ;
    dcterms:conformsTo ?conformsTo ;
    dcat:spatialResolutionInMeters ?spatialResolution ;
    dcat:temporalResolution ?temporalResolution ;
    dcterms:isPartOf ?topDatasetNew ;
    dcat:inSeries ?topDatasetNew ;
    dcat:distribution ?distribution_new ;
    dcterms:publisher ?publisher ;
    dcterms:identifier ?dataset_old_str ;
    dcatap:applicableLegislation ?datasetApplicableLegislation ;
    dcatap:hvdCategory ?datasethvdCategory .

  ?cp_new a ?cptype; 
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .

  ?publisher a foaf:Agent, foaf:Organization;
    foaf:name ?pname .

  ?temporal_new a dcterms:PeriodOfTime; 
    dcat:startDate ?finalStartDate ;
    dcat:endDate ?finalEndDate .

  ?distribution_new a dcat:Distribution ;
    dcat:downloadURL ?ddURL ;
    dcat:accessURL ?daURL ;
    dcterms:format ?dformat ;
    dcat:mediaType ?dmimeType ;
    dcterms:conformsTo ?dconformsTo ;
    dcat:compressFormat ?dcompressFormat ;
    dcat:packageFormat ?dpackageFormat ;
    dcterms:title ?dtitle ;
    dcatap:applicableLegislation ?distributionApplicableLegislation ;
    pu:specifikace ?tou_new .

  ?tou_new a pu:Specifikace ;
    pu:autorské-dílo ?touGeneral ;
    pu:databáze-jako-autorské-dílo ?touDatabase ;
    pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
    pu:osobní-údaje ?touPersonalData ;
    pu:autor ?touGeneralAuthor ;
    pu:autor-databáze ?touDatabaselAuthor .

  ?distribution_new dcat:accessService ?dataservice_new . 

  ?dataservice_new a dcat:DataService ;
    dcterms:title ?sTitle ;
    dcat:endpointURL ?sEndpointURL ;
    dcterms:conformsTo ?sConformsTo ;
    dcat:endpointDescription ?sEndpointDescription ;
    dcterms:identifier ?service_old_str ;
    dcatap:applicableLegislation ?dataServiceApplicableLegislation ;
    dcatap:hvdCategory ?dataServicehvdCategory ;
    foaf:page ?dataServiceDocumentation ;
    dcat:contactPoint ?dscp_new .

  ?dscp_new a ?dscptype; 
    vcard:fn ?dscpfn ;
    vcard:hasEmail ?dscpemail .

  ?record_new a dcat:CatalogRecord;
    foaf:primaryTopic ?dataset_new ;
    dcterms:source ?dataset ;
    dcterms:language <http://publications.europa.eu/resource/authority/language/CES>,
      <http://publications.europa.eu/resource/authority/language/ENG> ;
    dcterms:conformsTo <https://semiceu.github.io/DCAT-AP/releases/3.0.0> .
}
WHERE {
  # chunked:fileName jde z chunkování, je to link na metadata, která půjdou z extra souboru
  ?catalog a dcat:Catalog ;
    dcat:dataset ?dataset ;
    chunked:fileName ?filename .

  [] nkod:jméno-souboru ?filename ;
     nkod:datová-schránka-poskytovatele ?ds ;
     nkod:datová-zpráva-přijata ?rmodified .

  ?ds ^ds:datová-schránka ?publisher .
  ?publisher gr:legalName ?pname ;
             skos:notation ?publisherid .

  {?dataset a dcat:Dataset} UNION {?dataset a dcat:DatasetSeries }
  ?dataset a ?datasetType ;
             dcterms:title ?title ;
             dcterms:description ?description ;
             dcat:theme ?theme ;
             dcterms:accrualPeriodicity ?accrualPeriodicity ;
             dcat:keyword ?keyword ;
             dcterms:spatial ?spatial .

  OPTIONAL { ?dataset dcterms:temporal ?temporal . 
    OPTIONAL { ?temporal dcat:startDate ?startDate . }
    OPTIONAL { ?temporal dcat:endDate ?endDate . }
    OPTIONAL { ?temporal schema:startDate ?schemaStartDate . }
    OPTIONAL { ?temporal schema:endDate ?schemaEndDate . }
    BIND(IF(BOUND(?startDate), ?startDate, ?schemaStartDate) AS ?finalStartDate)
    BIND(IF(BOUND(?endDate), ?endDate, ?schemaEndDate) AS ?finalEndDate)
  }

  OPTIONAL { ?dataset dcat:contactPoint ?cp . 
    ?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { ?cp vcard:hasEmail ?cpemail . }
  }

  OPTIONAL { 
    ?dataset dcatap:applicableLegislation ?datasetApplicableLegislation . 
  }
  OPTIONAL { 
    ?dataset dcatap:hvdCategory ?datasethvdCategory . 
  }  

  OPTIONAL { ?dataset foaf:page ?page . }
  OPTIONAL { ?dataset dcterms:conformsTo ?conformsTo . }
  OPTIONAL { ?dataset dcat:spatialResolutionInMeters ?spatialResolution . }
  OPTIONAL { ?dataset dcat:temporalResolution ?temporalResolution . }
  OPTIONAL { ?dataset dcterms:isPartOf|dcat:inSeries ?topDataset . }

  OPTIONAL {
    ?dataset dcat:distribution ?distribution .
    ?distribution a dcat:Distribution ;
             dcat:accessURL ?daURL ;
             pu:specifikace ?tou .

    ?tou a pu:Specifikace ;
             pu:autorské-dílo ?touGeneral ;
             pu:databáze-jako-autorské-dílo ?touDatabase ;
             pu:databáze-chráněná-zvláštními-právy ?touDatabaseExtra ;
             pu:osobní-údaje ?touPersonalData .

    OPTIONAL { ?tou pu:autor ?touGeneralAuthor . }
    OPTIONAL { ?tou pu:autor-databáze ?touDatabaselAuthor . }

    OPTIONAL { ?distribution dcat:downloadURL ?ddURL . }
    OPTIONAL { 
      ?distribution dcatap:applicableLegislation ?distributionApplicableLegislation . 
    }
    OPTIONAL { ?distribution dcterms:format ?dformat . }
    OPTIONAL { ?distribution dcat:mediaType ?dmimeType . }
    OPTIONAL { ?distribution dcterms:conformsTo ?dconformsTo . }
    OPTIONAL { ?distribution dcat:compressFormat ?dcompressFormat . }
    OPTIONAL { ?distribution dcat:packageFormat ?dpackageFormat . }
    OPTIONAL { ?distribution dcterms:title ?dtitle . }

    OPTIONAL { 
      ?distribution dcat:accessService ?dataService . 
      ?dataService a dcat:DataService ;
                    dcterms:title ?sTitle ;
                    dcat:endpointURL ?sEndpointURL .

      OPTIONAL { ?dataService dcat:endpointDescription ?sEndpointDescription .}
      OPTIONAL { ?dataService dcterms:conformsTo ?sConformsTo .}
      OPTIONAL { 
        ?dataService dcatap:applicableLegislation ?dataServiceApplicableLegislation . 
        FILTER(isIRI(?dataServiceApplicableLegislation))
      }
      OPTIONAL { 
        ?dataService dcatap:hvdCategory ?dataServicehvdCategory . 
        FILTER(isIRI(?dataServicehvdCategory))
      }
      OPTIONAL { 
        ?dataService foaf:page ?dataServiceDocumentation . 
        FILTER(isIRI(?dataServiceDocumentation))
      }
      OPTIONAL { ?dataService dcat:contactPoint ?dscp . 
        ?dscp a ?dscptype.
        OPTIONAL { ?dscp vcard:fn ?dscpfn . }
        OPTIONAL { 
          ?dscp vcard:hasEmail ?dscpemail . 
          FILTER(isIRI(?dscpemail))
        }
      }      
    }
  }

  BIND (STRDT(STR(?dataset), xsd:anyURI) as ?dataset_old_str)
  BIND (STRDT(STR(?dataService), xsd:anyURI) as ?service_old_str)
  BIND (CONCAT(\"https://data.gov.cz/zdroj/datové-sady/\", ?publisherid, \"/\") as ?new_IRI_base)
  BIND (IRI(CONCAT(?new_IRI_base, MD5(STR(?dataset)))) as ?dataset_new)
  BIND (IRI(CONCAT(?new_IRI_base, MD5(STR(?topDataset)))) as ?topDatasetNew)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/distribuce/\", MD5(STR(?distribution)))) as ?distribution_new)
  BIND (IRI(CONCAT(STR(?distribution_new),\"/datová-služba/\", MD5(STR(?dataService)))) as ?dataservice_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/záznam\")) as ?record_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/kontaktní-bod\")) as ?cp_new)
  BIND (IRI(CONCAT(STR(?dataservice_new),\"/kontaktní-bod\")) as ?dscp_new)
  BIND (IRI(CONCAT(STR(?distribution_new),\"/podmínky-užití\")) as ?tou_new)
  BIND (IRI(CONCAT(STR(?dataset_new),\"/časové-pokrytí\")) as ?temporal_new)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779164/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779164/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#query> """PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
DELETE { 
  ?distribution <https://data.gov.cz/slovník/podmínky-užití/specifikace> ?tou .
  ?tou a <https://data.gov.cz/slovník/podmínky-užití/Specifikace> .
} 
WHERE 
{
  ?distribution <https://data.gov.cz/slovník/podmínky-užití/specifikace> ?tou .
  ?tou a <https://data.gov.cz/slovník/podmínky-užití/Specifikace> .
  FILTER NOT EXISTS { ?tou
      <https://data.gov.cz/slovník/podmínky-užití/autorské-dílo> [] ;
      <https://data.gov.cz/slovník/podmínky-užití/databáze-jako-autorské-dílo> [] ;
      <https://data.gov.cz/slovník/podmínky-užití/databáze-chráněná-zvláštními-právy> [] ;
      <https://data.gov.cz/slovník/podmínky-užití/osobní-údaje> [].
}
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdateChunked#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779166/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779166/configuration>
    a <http://plugins.linkedpipes.com/ontology/e-filesFromLocal#Configuration>;
    <http://plugins.linkedpipes.com/ontology/e-filesFromLocal#path> "/data/adapter/registrations/attachments";
    <http://plugins.linkedpipes.com/ontology/e-filesFromLocal#pathControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779168/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779168/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#query> """PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

INSERT {
?starýDataset nkod:max_čas_úpravy ?max_čas_úpravy .
}
WHERE {
    {
    	SELECT (MAX(?čas) AS ?max_čas_úpravy) ?starýDataset 
    	WHERE { ?d nkod:upravuje ?starýDataset ;
	        nkod:čas_úpravy ?čas . 
	    }
	    GROUP BY ?starýDataset
	}
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779169/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779169/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX srtfl: <http://plugins.linkedpipes.com/ontology/t-sparqlConstructToFileList#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>

CONSTRUCT 
{
<https://localhost/nkod-task> a srtfl:Task ;
    srtfl:fileName \"lkods.trig\" ;
    srtfl:fileFormat \"application/trig\" ;
    srtfl:hasTaskQuery ?tqIRI .

?tqIRI a srtfl:TaskQuery ;
    srtfl:outputGraph ?catalog ;
    srtfl:query ?query .
} 

WHERE 
{ 
?catalog a dcat:Catalog .

BIND(UUID() as ?tqIRI)
BIND(CONCAT(\"\"\"
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>

CONSTRUCT {
<\"\"\",STR(?catalog),\"\"\"> a dcat:Catalog, ?typKatalogu ;
    dcterms:title ?title ;
    dcat:endpointURL ?endpoint ;
    dcat:contactPoint ?cp_new ;
    dcterms:publisher ?publisher ;
    foaf:homepage ?homepage .

?cp_new a ?cptype ;
    vcard:fn ?cpfn ;
    vcard:hasEmail ?cpemail .

<https://data.gov.cz/zdroj/katalog/NKOD> dcterms:hasPart <\"\"\",STR(?catalog),\"\"\"> .
}
WHERE {
<\"\"\",STR(?catalog),\"\"\"> a dcat:Catalog, ?typKatalogu ;
    dcterms:title ?title ;
    dcterms:publisher ?publisher ;
    dcat:endpointURL ?endpoint .
    
FILTER(?typKatalogu != dcat:Catalog)

OPTIONAL { <\"\"\",STR(?catalog),\"\"\"> dcat:contactPoint ?cp . 
?cp a ?cptype.
    OPTIONAL { ?cp vcard:fn ?cpfn . }
    OPTIONAL { ?cp vcard:hasEmail ?cpemail . }
BIND(IRI(\\\"\"\"\",STR(?catalog),\"\"\"/kontaktní-bod\\\") AS ?cp_new)
}
OPTIONAL { <\"\"\",STR(?catalog),\"\"\"> foaf:homepage ?homepage . }

}
\"\"\") as ?query)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-0001161103893177916110389317791611038931779170/configuration> {
