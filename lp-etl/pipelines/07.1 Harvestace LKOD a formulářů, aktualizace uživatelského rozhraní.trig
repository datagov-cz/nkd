      \"cs\": {
        \"type\": \"primitive\",
        \"selectors\": [
          {
            \"type\": \"Filter\",
            \"condition\": \"Equal\",
            \"value\": \"cs\",
            \"path\": [
              \"@language\"
            ]
          },
          {
            \"type\": \"Path\",
            \"path\": [
              \"@value\"
            ]
          },
          {
            \"type\": \"Once\"
          }
        ],
        \"output\": {
          \"type\": \"JsonOutput\",
          \"dataType\": \"string\"
        }
      },
      \"en\": {
        \"type\": \"primitive\",
        \"selectors\": [
          {
            \"type\": \"Filter\",
            \"condition\": \"Equal\",
            \"value\": \"en\",
            \"path\": [
              \"@language\"
            ]
          },
