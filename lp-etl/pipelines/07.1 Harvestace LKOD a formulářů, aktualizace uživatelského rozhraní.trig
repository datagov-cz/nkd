      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#headerAcceptControl>
      <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#literals> "dsID";
    <http://plugins.linkedpipes.com/ontology/e-sparqlEndpointChunked#literalsControl>
