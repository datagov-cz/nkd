<https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/aa8b-9d14/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/aa8b-9d14/configuration>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX : <http://plugins.linkedpipes.com/ontology/t-filesFilter#>

CONSTRUCT { 
<http://localhost/pipeline/component/configuration> a :Configuration ;
    :fileNamePattern ?pattern .
}
WHERE { 
  [] <urn:useHistoricRecords> ?zpracovatHistorickéZáznamy .
  VALUES (?zpracovatHistorickéZáznamy ?pattern) {
    (true \"^.*zip$\")
    (false \"^$\")
  }
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

