    <http://plugins.linkedpipes.com/ontology/t-sparqlSelect#query> """PREFIX nkod: <https://data.gov.cz/slovník/nkod/>
SELECT DISTINCT ?dsID WHERE {
  [] a nkod:PřijatýZáznam ;
     nkod:datová-schránka-poskytovatele ?ds .
  
  BIND(STRAFTER(STR(?ds),\"https://data.gov.cz/zdroj/datové-schránky/\") AS ?dsID)
}""";
