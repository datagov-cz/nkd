<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317793868-a7a2/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317793868-a7a2/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputMode> <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#addToChunk>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#outputModeControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX pojmy: <https://slovník.gov.cz/legislativní/sbírka/111/2009/pojem/>

CONSTRUCT { 
  ?dataset a <https://data.gov.cz/slovník/nkod/vdf/číselník> .
} 
WHERE 
{  
  ?dataset a dcat:Dataset .
  
  ?údaj a pojmy:údaj ;
  	pojmy:je-kódovaný-číselníkem/pojmy:iri-číselníku-v-nkod ?dataset .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFail> false;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#softFailControl> <http://plugins.linkedpipes.com/resource/configuration/None>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threads> 8;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#threadsControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317793a58-83f5/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/16110389317791764943595711-00011611038931779161103893177916110389317793a58-83f5/1>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

PREFIX ds: <https://data.gov.cz/slovník/datové-schránky/>
PREFIX tds: <https://data.gov.cz/slovník/datové-schránky/typ-datové-schránky/>
PREFIX nkod: <https://data.gov.cz/slovník/nkod/>

CONSTRUCT { 
?poskytovatel gr:legalName ?jméno;
  skos:notation ?ičo ;
  ds:datová-schránka ?ds .

} 
WHERE { 
?poskytovatel gr:legalName ?jméno;
  skos:notation ?ičo ;
  ds:datová-schránka ?ds .

?ds a ?typ .
  FILTER (
    EXISTS { ?poskytovatel a nkod:PovolenýPoskytovatel}
    ||
    EXISTS { ?ds a ?typ
      #typy z https://www.mojedatovaschranka.cz/sds/p/download/sds_datove_soubory.pdf
      FILTER (?typ IN (tds:OVM, tds:OVM_PO, tds:OVM_PFO, tds:OVM_FO , tds:OVM_REQ ))
    })
}
""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

