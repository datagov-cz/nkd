<https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/bfe4-9a22/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/bfe4-9a22/configuration>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
CONSTRUCT WHERE { 
  ?catalog a dcat:Catalog ;
     dcat:contactPoint ?cp .
  
  ?cp a ?cptype;
      vcard:fn ?fn ;
      vcard:hasEmail ?email .
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/d5c7-9603/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/d5c7-9603/configuration>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#query> """PREFIX vcard: <http://www.w3.org/2006/vcard/ns#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
DELETE { 
	?finalCatalogIRI dcat:contactPoint ?registeredCP .
  	?registeredCP a ?registeredCPtype ;
        vcard:fn ?registeredFn ;
    	vcard:hasEmail ?registeredEmail .
}
INSERT { 
	?finalCatalogIRI dcat:contactPoint ?harvestedCP .
  	?harvestedCP a ?harvestedCPtype ; 
        vcard:fn ?harvestedFn ;
    	vcard:hasEmail ?harvestedEmail .
} 
WHERE { 
  ?finalCatalogIRI a dcat:Catalog ;
      dcat:endpointURL ?catalogURL .
    
  ?catalogURL dcat:contactPoint ?harvestedCP .
  ?harvestedCP a ?harvestedCPtype ; 
      vcard:fn ?harvestedFn ;
      vcard:hasEmail ?harvestedEmail .
  
  OPTIONAL {
   ?finalCatalogIRI dcat:contactPoint ?registeredCP .
   ?registeredCP a ?registeredCPtype ;
    	vcard:fn ?registeredFn ;
        vcard:hasEmail ?registeredEmail .
  }
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlUpdate#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/d8b1-96b3/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/1611038931779/component/d8b1-96b3/configuration>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX req: <http://plugins.linkedpipes.com/ontology/x-httpRequest#>

CONSTRUCT { 

<http://localhost/slack> a req:Task ;
  req:url ?url ;
  req:method \"POST\" ;
  req:postContentAsBody true ;
  req:content <http://localhost/slack/content> .

<http://localhost/slack/content> a req:Content ;
  req:fileReference \"configuration.json\" . } 
WHERE { 
  [] <urn:slackToken> ?token .
  BIND(CONCAT(\"https://hooks.slack.com/services/\", ?token) AS ?url)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

