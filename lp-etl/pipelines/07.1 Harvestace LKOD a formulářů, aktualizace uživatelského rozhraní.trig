@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcatap:     <http://data.europa.eu/r5r/> .

<https://data.gov.cz/zdroj/datová-sada/NKOD> {
	<https://data.gov.cz/zdroj/katalog/NKOD> a dcat:Catalog ;
	dcterms:title \"Národní katalog otevřených dat České republiky (NKOD)\"@cs, \"Czech National Open Data Catalog\"@en ;
	dcterms:description \"Národní katalog otevřených dat České republiky (NKOD)\"@cs, \"Czech National Open Data Catalog\"@en ;
	dcterms:publisher <https://rpp-opendata.egon.gov.cz/odrpp/zdroj/orgán-veřejné-moci/17651921> ;
	foaf:homepage <https://data.gov.cz> ;
	dcterms:language <http://publications.europa.eu/resource/authority/language/CES>, <http://publications.europa.eu/resource/authority/language/ENG> ;
    dcterms:license <https://data.gov.cz/podmínky-užití/volný-přístup/> ;
	dcterms:issued \"2015-04-01\"^^xsd:date ;
	dcat:themeTaxonomy <http://publications.europa.eu/resource/authority/data-theme>, <http://eurovoc.europa.eu/schema#EuroVoc> ;
    dcterms:spatial <http://publications.europa.eu/resource/authority/country/CZE>, <https://linked.cuzk.cz/resource/ruian/stat/1> .

<https://rpp-opendata.egon.gov.cz/odrpp/zdroj/orgán-veřejné-moci/17651921> rdf:type schema:Organization, foaf:Agent, <http://data.europa.eu/m8g/PublicOrganisation> ;
   foaf:name \"Digitální a informační agentura\"@cs, \"Digital and Information agency\"@en .

<http://publications.europa.eu/resource/authority/data-theme> a skos:ConceptScheme;
	dcterms:title \"EU dataset theme\"@en .

<http://eurovoc.europa.eu/schema#EuroVoc> a skos:ConceptScheme;
	dcterms:title \"EuroVoc slovník\"@cs, \"EuroVoc Thesauri\"@en .
}""";
