<https://oha02.dia.gov.cz/etl/resources/pipelines/1749468953491-0002/component/ae02-942e/configuration> {
  <https://oha02.dia.gov.cz/etl/resources/pipelines/1749468953491-0002/component/ae1a-a3ac/configuration>
    a <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#Configuration>;
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#query> """PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>

PREFIX httpList: <http://plugins.linkedpipes.com/ontology/e-httpGetFiles#>

CONSTRUCT {
<http://localhost/resource/configuration> a httpList:Configuration ;
    httpList:reference ?distribuce .

?distribuce a httpList:Reference ;
    httpList:fileUri ?stažení ;
    httpList:fileName ?filename ;
    httpList:header ?agentHeader .

?agentHeader a httpList:Header ;
    httpList:key \"User-Agent\" ;
    httpList:value \"nkod/0.0.2\" .
}
WHERE {
  ?slovník a dcat:Dataset ;
    dcterms:conformsTo ?OFNSlovníky;
    dcat:distribution ?distribuce .
  ?distribuce a dcat:Distribution ;
    dcat:downloadURL ?stažení.
  
  BIND(REPLACE(STR(?stažení),\"[:/\\\\?#&]\",\"-\") as ?filename)
  BIND(IRI(CONCAT(STR(?stažení),\"/agent-header\")) as ?agentHeader)
}""";
    <http://plugins.linkedpipes.com/ontology/t-sparqlConstruct#queryControl> <http://plugins.linkedpipes.com/resource/configuration/None> .
}

<https://oha02.dia.gov.cz/etl/resources/pipelines/1749468953491-0002/component/ae1a-a3ac/configuration> {
